{% assign title  =  'buttons.create_post' | t %}
{% set_meta_title title %}
{% if current_user %}
  <main class="grow bg-base-100">
    <section class="relative">
      <!-- Illustration -->
      <div class="absolute -translate-x-1/2 pointer-events-none left-1/2 -z-10" aria-hidden="true">
          <img src="{{ 'images/demo/hero-illustration.svg' | asset_url }}" class="max-w-none" width="1905" height="622" alt="Hero Illustration">
      </div>
      <div class="max-w-6xl px-4 mx-auto sm:px-6">
        <div class="pt-6 md:pt-12">
          <div class="md:flex md:justify-between md:divide-x md:divide-base-300">
            <div class="md:grow ">
              <!-- Post header -->
              <header class="mb-4">
                <h1 class="mb-4 h3 md:h3 font-aspekta ">{{ 'buttons.create_post' | t }}</h1>
                <p class="text-sm text-base-content/60">{{ 'me.post_hint' | t }} <a href="{{ statics['me'] }}" class="text-primary hover:underline">{{ 'generic.my_community' | t }}</a></p>
              </header>
              <!-- Page content -->
              <div class="md:grow ">
                <div class="md:pr-6 lg:pr-20">
                  {% include 'community_daily_limit' %}
                  {% render 'community_daily_limit_alert', community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}
                  {% unless community_daily_limit_reached %}
                    {% form_tag 'page' %}
                      {% render 'page_form', page: page,  action: 'create' %}
                    {% endform_tag %}
                  {% endunless %}
                </div>
              </div>
            </div>

            <!-- Sidebar -->
            <aside class="pt-6 pb-12 md:w-64 lg:w-80 md:shrink-0 md:pb-20">
            </aside>
          </div>
        </div>
      </div>
    </section>
  </main>
{% else %}
<div class="w-2/3 px-2 mx-auto sm:px-6 min-h-fit">
    {{ 'buttons.redirect_to' | t }}
    {% form_tag 'sign_in_with_baklib' %}
      <input value="true" type="hidden" name="sign_up">
      <input type="submit"
        value="{{ 'buttons.login' | t }}"
        class="items-center hidden px-3 py-2 text-sm font-medium text-primary-content transition duration-150 ease-in-out hover:text-primary-content/80 lg:px-5"
        data-disable-with=" ... " x-init="$el.click()"
        >
    {% endform_tag %}

</div>
{% endif %}