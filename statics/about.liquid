{% assign _about_meta = 'about.meta_title' | t %}
{% set_meta_title _about_meta %}

<main class="grow">
  <section>
    <div class="max-w-6xl px-4 mx-auto sm:px-6">
      <div class="pt-6 md:pt-12">
        <header class="mb-8">
          <h1 class="text-2xl font-bold text-base-content mb-2">
            {{ 'about.title' | t }}
          </h1>
          <p class="text-base-content/70">
            {{ 'about.subtitle' | t }}
          </p>
        </header>

        <div class="mb-10">
          <h2 class="text-xl font-semibold text-base-content mb-4">
            {{ 'about.section_intro' | t }}
          </h2>
          <div class="prose dark:prose-invert max-w-none">
            <p>{{ 'about.intro_p1' | t }}</p>
            <p class="text-base-content/70">{{ 'about.intro_scope' | t }}</p>
          </div>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-semibold text-base-content mb-4">
            {{ 'about.section_features' | t }}
          </h2>
          <ul class="space-y-2 text-base-content ml-4">
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_posts' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_replies' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_tags' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_timeline' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_related' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_feedback' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_search' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_moderation' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_responsive' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_dark' | t }}</span></li>
            <li class="flex items-start gap-2"><span class="text-primary shrink-0">•</span><span>{{ 'about.feat_turbo' | t }}</span></li>
          </ul>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-semibold text-base-content mb-4">
            {{ 'about.section_tutorial' | t }}
          </h2>

          <div class="space-y-6 ml-4">
            <div class="border border-base-300 rounded-xl p-5 bg-base-200">
              <h3 class="text-lg font-medium text-base-content mb-2">{{ 'about.tut_install_title' | t }}</h3>
              <p class="text-base-content/70 mb-2">{{ 'about.tut_install_body' | t }}</p>
              <p><code class="text-sm px-1.5 py-0.5 rounded bg-base-200">https://gitee.com/baklib/community-question</code></p>
            </div>

            <div class="border border-base-300 rounded-xl p-5 bg-base-200">
              <h3 class="text-lg font-medium text-base-content mb-2">{{ 'about.tut_app_title' | t }}</h3>
              <p class="text-base-content/70 mb-3">{{ 'about.tut_app_intro' | t }}</p>
              <ul class="list-inside space-y-1.5 text-base-content/70 text-sm">
                <li>{{ 'about.tut_app_logo' | t }}</li>
                <li>{{ 'about.tut_app_avatar' | t }}</li>
                <li>{{ 'about.tut_app_review' | t }}</li>
                <li>{{ 'about.tut_app_emoji' | t }}</li>
                <li>{{ 'about.tut_app_copy' | t }}</li>
                <li>{{ 'about.tut_app_nav' | t }}</li>
              </ul>
            </div>

            <div class="border border-base-300 rounded-xl p-5 bg-base-200">
              <h3 class="text-lg font-medium text-base-content mb-2">{{ 'about.tut_home_title' | t }}</h3>
              <p class="text-base-content/70 mb-2">{{ 'about.tut_home_intro' | t }}</p>
              <ul class="list-inside space-y-1 text-base-content/70 text-sm">
                <li>{{ 'about.tut_home_index' | t }}</li>
                <li>{{ 'about.tut_home_forum' | t }}</li>
              </ul>
              <p class="text-base-content/70 mt-3 mb-2">{{ 'about.tut_home_detail' | t }}</p>
            </div>

            <div class="border border-base-300 rounded-xl p-5 bg-base-200">
              <h3 class="text-lg font-medium text-base-content mb-2">{{ 'about.tut_hero_title' | t }}</h3>
              <p class="text-base-content/70 mb-2">{{ 'about.tut_hero_intro' | t }}</p>
              <ul class="list-inside space-y-1 text-base-content/70 text-sm">
                <li>{{ 'about.tut_hero_li1' | t }}</li>
                <li>{{ 'about.tut_hero_li2' | t }}</li>
                <li>{{ 'about.tut_hero_li3' | t }}</li>
              </ul>
            </div>

            <div class="border border-base-300 rounded-xl p-5 bg-base-200">
              <h3 class="text-lg font-medium text-base-content mb-2">{{ 'about.tut_cols_title' | t }}</h3>
              <p class="text-base-content/70 text-sm">{{ 'about.tut_cols_body' | t }}</p>
            </div>
          </div>
        </div>

        <div class="border-t border-base-300 pt-8">
          <h2 class="text-xl font-semibold text-base-content mb-4">
            {{ 'about.section_links' | t }}
          </h2>
          <ul class="space-y-2">
            <li>
              <a href="https://help.baklib.cn/themes/community/question" target="_blank" rel="noopener" class="text-base-content hover:underline underline-offset-2 underline">{{ 'about.link_help' | t }}</a>
            </li>
            <li>
              <a href="https://demo-question.uibak.com/" target="_blank" rel="noopener" class="text-base-content hover:underline underline-offset-2 underline">{{ 'about.link_demo' | t }}</a>
            </li>
            <li>
              <a href="https://community.baklib.cn/" target="_blank" rel="noopener" class="text-base-content hover:underline underline-offset-2 underline">{{ 'about.link_case' | t }}</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</main>
