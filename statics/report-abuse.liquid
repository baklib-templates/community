{% assign index_path = site.index_path | default: '/' %}
{% assign feedback_page_path = site.index_path | default: '/' %}
{% assign default_feedback_type = site.plugins.feedback.useful_types | first %}
{% assign default_feedback_emoji = default_feedback_type.emoji | default: site.settings.feedback_useful_type | default: '' %}
{% assign reported_url = params.url | default: '' | strip %}
{% assign feedback_message_enabled = false %}
{% if site.plugins.feedback.message_enabled %}
  {% assign feedback_message_enabled = true %}
{% endif %}
{% if site.settings.is_allow_feedback == false %}
  {% assign feedback_message_enabled = false %}
{% endif %}

{% assign _meta = 'report_abuse.meta_title' | t %}
{% set_meta_title _meta %}

<main class="grow">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-10 md:py-14">
    <nav class="flex items-center gap-2 text-sm text-base-content/60 mb-6" aria-label="Breadcrumb">
      <a href="{{ index_path }}" class="inline-flex items-center gap-1.5 hover:text-base-content transition-colors">
        {% render 'icon', name: 'home', class: 'size-4' %}
        <span>{{ 'generic.home' | t }}</span>
      </a>
      <span class="text-base-content/30">/</span>
      <span class="text-base-content">{{ 'report_abuse.title' | t }}</span>
    </nav>

    <header class="mb-8">
      <p class="mb-2 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-base-content/50">
        {% render 'icon', name: 'triangle-alert', class: 'size-3.5' %}
        <span>{{ 'report_abuse.eyebrow' | t }}</span>
      </p>
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-base-content">{{ 'report_abuse.title' | t }}</h1>
      <p class="mt-3 text-base text-base-content/70 leading-relaxed">{{ 'report_abuse.subtitle' | t }}</p>
    </header>

    {% if feedback_message_enabled %}
      <section data-controller="report-abuse-feedback">
        {% form_tag 'feedback' %}
          <input type="hidden" name="feedback[page_path]" value="{{ feedback_page_path }}" />
          <input type="hidden" name="{{ form.feedback_message_field_name }}" data-report-abuse-feedback-target="messageField" />
          <input type="hidden" name="{{ form.feedback_emoji_field_name }}" value="{{ default_feedback_emoji | escape_once }}" />

          <div class="space-y-6 rounded-2xl border border-base-300 bg-base-200 p-5 sm:p-8 shadow-sm">
            <div role="alert" data-report-abuse-feedback-target="formError" class="hidden items-start gap-2 rounded-xl border border-error/40 bg-error/10 px-3 py-2.5 text-sm text-error">
              {% render 'icon', name: 'info', class: 'size-4 shrink-0' %}
              <span>{{ 'report_abuse.error' | t }}</span>
            </div>

            <fieldset>
              <legend class="mb-3 text-sm font-semibold text-base-content">
                {{ 'report_abuse.fields.category' | t }} <span class="text-error">*</span>
              </legend>
              <div class="space-y-2">
                <label class="flex items-center gap-2.5 text-sm text-base-content cursor-pointer">
                  <input type="radio" name="report_category" value="rude_or_vulgar" class="radio radio-sm" data-report-abuse-feedback-target="category" />
                  <span>{{ 'report_abuse.categories.rude_or_vulgar' | t }}</span>
                </label>
                <label class="flex items-center gap-2.5 text-sm text-base-content cursor-pointer">
                  <input type="radio" name="report_category" value="harassment" class="radio radio-sm" data-report-abuse-feedback-target="category" />
                  <span>{{ 'report_abuse.categories.harassment' | t }}</span>
                </label>
                <label class="flex items-center gap-2.5 text-sm text-base-content cursor-pointer">
                  <input type="radio" name="report_category" value="spam" class="radio radio-sm" data-report-abuse-feedback-target="category" />
                  <span>{{ 'report_abuse.categories.spam' | t }}</span>
                </label>
                <label class="flex items-center gap-2.5 text-sm text-base-content cursor-pointer">
                  <input type="radio" name="report_category" value="other" class="radio radio-sm" data-report-abuse-feedback-target="category" />
                  <span>{{ 'report_abuse.categories.other' | t }}</span>
                </label>
              </div>
              <p role="alert" data-report-abuse-feedback-target="categoryError" class="mt-2 hidden text-xs text-error">{{ 'report_abuse.required' | t }}</p>
            </fieldset>

            <div>
              <label for="report-abuse-url" class="mb-1.5 block text-sm font-semibold text-base-content">
                {{ 'report_abuse.fields.url' | t }} <span class="text-error">*</span>
              </label>
              <input
                id="report-abuse-url"
                type="url"
                required
                value="{{ reported_url | escape }}"
                data-report-abuse-feedback-target="url"
                aria-describedby="report-abuse-url-error"
                class="form-input w-full"
                placeholder="https://"
              />
              <p id="report-abuse-url-error" role="alert" data-report-abuse-feedback-target="urlError" class="mt-1 hidden text-xs text-error">{{ 'report_abuse.required' | t }}</p>
            </div>

            <div>
              <label for="report-abuse-contact" class="mb-1.5 block text-sm font-semibold text-base-content">
                {{ 'report_abuse.fields.contact' | t }}
              </label>
              <input
                id="report-abuse-contact"
                type="text"
                data-report-abuse-feedback-target="contact"
                class="form-input w-full"
                placeholder="{{ 'report_abuse.fields.contact_placeholder' | t }}"
              />
            </div>

            <div>
              <label for="report-abuse-message" class="mb-1.5 block text-sm font-semibold text-base-content">
                {{ 'report_abuse.fields.message' | t }} <span class="text-error">*</span>
              </label>
              <p class="mb-2 text-xs text-base-content/55">{{ 'report_abuse.fields.message_hint' | t }}</p>
              <textarea
                id="report-abuse-message"
                rows="5"
                required
                data-report-abuse-feedback-target="message"
                aria-describedby="report-abuse-message-error"
                class="form-textarea w-full"
                placeholder="{{ 'report_abuse.fields.message_placeholder' | t }}"
              ></textarea>
              <p id="report-abuse-message-error" role="alert" data-report-abuse-feedback-target="messageError" class="mt-1 hidden text-xs text-error">{{ 'report_abuse.required' | t }}</p>
            </div>

            <div class="flex flex-col gap-3 pt-1 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-xs text-base-content/55">{{ 'report_abuse.success_hint' | t }}</p>
              <button
                type="button"
                data-action="report-abuse-feedback#submit"
                data-report-abuse-feedback-target="submit"
                class="btn2 inline-flex items-center justify-center gap-2"
              >
                {% render 'icon', name: 'check', class: 'size-4' %}
                <span data-report-abuse-feedback-target="submitLabel">{{ 'report_abuse.submit' | t }}</span>
                <span data-report-abuse-feedback-target="submittingLabel" class="hidden">{{ 'report_abuse.submitting' | t }}</span>
              </button>
            </div>
          </div>
        {% endform_tag %}
      </section>
    {% else %}
      <div class="flex items-start gap-3 rounded-2xl border border-base-300 bg-base-200/60 p-6 text-sm text-base-content/70">
        {% render 'icon', name: 'info', class: 'size-5 shrink-0 text-base-content/50' %}
        <p>{{ 'report_abuse.unavailable' | t }}</p>
      </div>
    {% endif %}
  </section>
</main>
