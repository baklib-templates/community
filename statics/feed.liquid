{% assign title  =  'generic.feeds' | t %}
{% set_meta_title title %}

{% assign pages = site.pages['/'].children_in_list | order_by: "-created_at" %}
{% query pinned_pages from site.pages['/'].children_in_list %}
  {
    "where": { "settings.pinned_true": true },
    "order_by": ["-created_at"],
    "limit": 50
  }
{% endquery %}

<section class="max-w-4xl mx-auto bg-base-100">
  <div class="my-12">
    <!-- Content header -->
    <div class="pb-6 mb-4 border-b border-base-300">
        <h2 class="text-xl font-semibold">{{ 'generic.feeds' | t }}</h2>
    </div>
    <!-- List container -->
    <turbo-frame id="pages_list" class="flex flex-col mb-8 space-y-3">
        {% render 'pages_list', pages: pages, pinned_pages: pinned_pages %}
        <!-- Sponsored item -->
    </turbo-frame>
  </div>
</section>
