{% assign title  =  'generic.feeds' | t %}
{% set_meta_title title %}

{% assign pages = site.pages['/'].children_in_list | order_by: "-created_at" %}

<section class="max-w-4xl mx-auto">
  <div class="my-12">
    <!-- Content header -->
    <div class="pb-6 mb-4 border-b border-slate-200 dark:border-slate-800">
        <h2 class="text-xl font-semibold">{{ 'generic.feeds' | t }}</h2>
    </div>
    <!-- List container -->
    <turbo-frame id="pages_list" class="flex flex-col mb-8 space-y-3">
        {% paginate_tag pages, per: 10 %}
            {% for sub_page in pages %}
                {% render 'page', page: sub_page %}
            {% endfor %}
            {% render 'paginate', paginate: paginate %}
        {% endpaginate_tag %}
        <!-- Sponsored item -->
    </turbo-frame>
  </div>
</section>
