{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url %}
  {% assign default_avatar_url = 'images/avatar.svg' | asset_url %}
{% endunless %}

<main class="grow">
  <section class="relative">
    <div class="absolute -translate-x-1/2 pointer-events-none left-1/2 -z-10" aria-hidden="true">
      <img src="{{ 'images/demo/hero-illustration.svg' | asset_url }}" class="max-w-none" width="1905" height="622" alt="">
    </div>

    <div class="max-w-7xl px-4 mx-auto sm:px-6">
      <div class="pt-12 md:pt-20">
        <div class="md:flex md:justify-between">
          <div class="md:grow max-w-3xl">
            <div class="md:pr-6 lg:pr-12">

              {% unless current_user %}
                <div class="text-center py-16">
                  <h1 class="h2 font-aspekta mb-4">{{ 'me.title' | t }}</h1>
                  <p class="text-base-content/70 mb-6">{{ 'me.login_required' | t }}</p>
                  <a href="{{ current_site.login_url }}" class="btn2 btn2-primary">{{ 'buttons.login' | t }}</a>
                </div>
              {% else %}
                <div class="mb-8">
                  <h1 class="h2 font-aspekta mb-2">{{ 'me.title' | t }}</h1>
                  <p class="text-base-content/60">{{ 'me.subtitle' | t }}</p>
                </div>

                {% assign me_tab = params.tab | default: 'posts' %}
                {% assign my_pages = current_user.pages | order_by: '-created_at' %}
                {% assign related_pages = site.pages['/'].children_in_list | where: 'related', current_user.member_id | order_by: '-created_at' %}
                {% assign my_pages_size = my_pages | size %}
                {% assign related_pages_size = related_pages | size %}
                {% query inbox_replies from site.comments %}
                  {
                    "where": {
                      "reply_to_user_id_eq": {{ current_user.id }}
                    },
                    "order_by": ["-created_at"],
                    "limit": 50
                  }
                {% endquery %}

                <div role="tablist" class="tabs tabs-border tabs-lg w-full mb-6 overflow-x-auto">
                  <a role="tab" href="{{ statics['me'] }}?tab=posts" class="tab gap-2 {% if me_tab == 'posts' or me_tab == blank %}tab-active{% endif %}" {% if me_tab == 'posts' or me_tab == blank %}aria-current="page"{% endif %}>
                    {% render 'icon', name: 'file-text', class: 'size-4 shrink-0' %}
                    <span>{{ 'me.tabs.posts' | t }}</span>
                    <span class="badge badge-sm badge-ghost">{{ my_pages_size }}</span>
                  </a>
                  <a role="tab" href="{{ statics['me'] }}?tab=related" class="tab gap-2 {% if me_tab == 'related' %}tab-active{% endif %}" {% if me_tab == 'related' %}aria-current="page"{% endif %}>
                    {% render 'icon', name: 'users', class: 'size-4 shrink-0' %}
                    <span>{{ 'me.tabs.related' | t }}</span>
                    <span class="badge badge-sm badge-ghost">{{ related_pages_size }}</span>
                  </a>
                  <a role="tab" href="{{ statics['me'] }}?tab=replies" class="tab gap-2 {% if me_tab == 'replies' %}tab-active{% endif %}" {% if me_tab == 'replies' %}aria-current="page"{% endif %}>
                    {% render 'icon', name: 'message-square', class: 'size-4 shrink-0' %}
                    <span>{{ 'me.tabs.replies' | t }}</span>
                  </a>
                </div>

                {% case me_tab %}
                {% when 'related' %}
                  <div class="space-y-2">
                    {% if related_pages_size == 0 %}
                      <p class="text-center text-base-content/50 py-12">{{ 'me.empty.related' | t }}</p>
                    {% else %}
                      {% for item in related_pages %}
                        {% render 'page', page: item, show_review_badge: false %}
                      {% endfor %}
                    {% endif %}
                  </div>

                {% when 'replies' %}
                  <div class="space-y-3">
                    {% assign inbox_empty = true %}
                    {% for reply in inbox_replies %}
                      {% assign inbox_empty = false %}
                      <div class="rounded-lg border border-base-300 bg-base-100 p-4">
                        <div class="flex items-start gap-3">
                          <img class="rounded-full shrink-0" src="{{ reply.author.avatar_url | default: default_avatar_url }}" width="36" height="36" alt="">
                          <div class="min-w-0 grow">
                            <div class="text-sm text-base-content/70 mb-1">
                              <span class="font-medium text-base-content">{{ reply.author.name }}</span>
                              <span class="mx-1">·</span>
                              <span>{{ reply.created_at | date: '%Y-%m-%d %H:%M' }}</span>
                            </div>
                            <div class="text-sm line-clamp-3 mb-2 break-words">{{ reply.body | strip_html | truncate: 160 }}</div>
                            {% if reply.target %}
                              <a href="{{ reply.target.path }}" class="text-sm text-primary hover:underline">
                                {{ 'me.view_post' | t }}: {{ reply.target.link_text | truncate: 40 }}
                              </a>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    {% endfor %}
                    {% if inbox_empty %}
                      <p class="text-center text-base-content/50 py-12">{{ 'me.empty.replies' | t }}</p>
                    {% endif %}
                  </div>

                {% else %}
                  <div class="space-y-2">
                    {% if my_pages_size == 0 %}
                      <p class="text-center text-base-content/50 py-12">{{ 'me.empty.posts' | t }}</p>
                      <div class="text-center">
                        <a href="{{ statics['new'] }}" class="btn2 btn2-primary">{{ 'buttons.create_post' | t }}</a>
                      </div>
                    {% else %}
                      {% for item in my_pages %}
                        {% render 'page', page: item, show_review_badge: true %}
                      {% endfor %}
                    {% endif %}
                  </div>
                {% endcase %}
              {% endunless %}

            </div>
          </div>

          <aside class="md:w-72 md:ml-6 shrink-0 mt-8 md:mt-0">
            <div class="sticky top-20 space-y-4">
              {% if current_user %}
                <div class="rounded-box border border-base-300 bg-base-100 p-4">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="avatar">
                      <div class="w-12 rounded-full">
                        <img src="{{ current_user.image | default: default_avatar_url }}" alt="">
                      </div>
                    </div>
                    <div class="min-w-0">
                      <div class="font-medium truncate">{{ current_user.name }}</div>
                      <div class="text-xs text-base-content/50">{{ 'me.sidebar.account' | t }}</div>
                    </div>
                  </div>
                  <a href="{{ current_user.profile_url }}" target="_blank" rel="noopener" class="btn2 btn2-ghost btn2-sm w-full">
                    {{ 'generic.account_profile' | t }}
                  </a>
                </div>
              {% endif %}
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>
</main>

{% schema %}
{
  "name": "t:settings_schema.community_templates.me_name",
  "settings": []
}
{% endschema %}
