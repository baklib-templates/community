{% assign collection_value = params.c | default: "" | strip %}
{% assign feature_value = params.f | default: "" | strip %}

{% assign _cp = 'tag_filter.collection_prefix' | t %}
{% assign _fp = 'tag_filter.feature_prefix' | t %}
{% assign _sep = 'tag_filter.pair_sep' | t %}
{% if collection_value != "" and feature_value != "" %}
  {% assign title = _cp | append: collection_value | append: _sep | append: _fp | append: feature_value %}
{% elsif collection_value != "" %}
  {% assign title = _cp | append: collection_value %}
{% elsif feature_value != "" %}
  {% assign title = _fp | append: feature_value %}
{% else %}
  {% assign title = 'tag_filter.all_posts' | t %}
{% endif %}

{% set_meta_title title %}

{%- comment -%}
  根据是否有 c / f 参数，决定 query 条件：
  - c + f 同时存在：AND 组合
  - 仅 c 或仅 f：单条件
  - 都没有：仅按 template_name 过滤
{%- endcomment -%}

{% assign results = nil %}
{% assign results_size = 0 %}

{% comment %}
  使用 query 根据 collection / feature 组合筛选 page 模板。
  写法参考官方示例：
  https://dev.baklib.cn/liquid/tags/4ece
{% endcomment %}

{% if collection_value != "" and feature_value != "" %}
  {% query results from site.pages %}
    {
      "where": {
        "and": {
          "template_name_eq": "page",
          "settings.collection_eq": params.c,
          "settings.feature_eq": params.f
        }
      },
      "order_by": ["created_at desc"]
    }
  {% endquery %}
{% elsif collection_value != "" %}
  {% query results from site.pages %}
    {
      "where": {
        "and": {
          "template_name_eq": "page",
          "settings.collection_eq": params.c
        }
      },
      "order_by": ["created_at desc"]
    }
  {% endquery %}
{% elsif feature_value != "" %}
  {% query results from site.pages %}
    {
      "where": {
        "and": {
          "template_name_eq": "page",
          "settings.feature_eq": params.f
        }
      },
      "order_by": ["created_at desc"]
    }
  {% endquery %}
{% else %}
  {% query results from site.pages %}
    {
      "where": {
        "and": {
          "template_name_eq": "page"
        }
      },
      "order_by": ["created_at desc"]
    }
  {% endquery %}
{% endif %}

{% assign results_size = results | size %}

{% assign collection_tags_raw = site.settings.collection_tags | default: "" %}
{% assign collection_options = collection_tags_raw | newline_to_br | split: "<br />" %}
{% assign feature_tags_raw = site.settings.feature_tags | default: "" %}
{% assign feature_options = feature_tags_raw | newline_to_br | split: "<br />" %}

<main class="grow">
  <section class="max-w-4xl mx-auto">
    <div class="my-12">
      <!-- Content header -->
      <div class="pb-6 mb-4 border-b border-base-300">
        <h1 class="text-xl font-semibold text-base-content">
          {{ title }}
        </h1>
      </div>

      <!-- Filter form -->
      <form method="get" action="/s/tag" class="mb-6 rounded-xl border border-base-300 bg-base-100/40 p-4">
        <div class="grid gap-3 md:grid-cols-2">
          <div>
            <label for="filter_collection" class="block text-xs font-medium text-base-content/60 mb-1">
              {{ 'tag_filter.filter_collection' | t }}
            </label>
            <select id="filter_collection" name="c" class="w-full text-sm rounded-lg border border-base-300 bg-base-100/60 px-2 py-1.5">
              <option value="">{{ 'generic.all' | t }}</option>
              {% for c in collection_options %}
                {% assign c_name = c | strip %}
                {% if c_name != "" %}
                  <option value="{{ c_name }}" {% if c_name == collection_value %}selected{% endif %}>{{ c_name }}</option>
                {% endif %}
              {% endfor %}
            </select>
          </div>

          <div>
            <label for="filter_feature" class="block text-xs font-medium text-base-content/60 mb-1">
              {{ 'tag_filter.filter_feature' | t }}
            </label>
            <select id="filter_feature" name="f" class="w-full text-sm rounded-lg border border-base-300 bg-base-100/60 px-2 py-1.5">
              <option value="">{{ 'generic.all' | t }}</option>
              {% for f in feature_options %}
                {% assign f_name = f | strip %}
                {% if f_name != "" %}
                  <option value="{{ f_name }}" {% if f_name == feature_value %}selected{% endif %}>{{ f_name }}</option>
                {% endif %}
              {% endfor %}
            </select>
          </div>

        </div>
        <div class="flex justify-end gap-2 mt-3">
          <a href="/s/tag" class="btn btn-sm btn-ghost">
            {{ 'tag_filter.reset' | t }}
          </a>
          <button type="submit" class="btn btn-sm">
            {{ 'generic.search' | t }}
          </button>
        </div>
      </form>

      {% if results_size > 0 %}
        <!-- List + Pagination -->
        {% paginate_tag results, per: 10 %}
          <div class="flex flex-col mb-6 space-y-3">
            {% for page in results %}
              {% render 'page', page: page %}
            {% endfor %}
          </div>
          {% render 'paginate', paginate: paginate %}
        {% endpaginate_tag %}
      {% else %}
        <p class="text-sm text-base-content/60">
          {{ 'tag_filter.empty_results' | t }}
        </p>
      {% endif %}
    </div>
  </section>
</main>

