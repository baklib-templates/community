<!DOCTYPE html>
<html lang="{{ site.language }}" class="bg-base-100 text-base-content">

<head>
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="author" content="Baklib">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% meta_tags %}

  {%- comment -%}
    Runtime color injection MUST be rendered before any stylesheet that
    consumes --color-* (daisyUI / main.css). Static tokens live in src/main.css.
  {%- endcomment -%}
  {% render 'theme_runtime_colors' %}

  {{ 'baklib/shared/editor.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
  {{ 'baklib/shared/editor.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
  {{ 'javascripts/main.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
  <!-- Tailwind -->
  {{ 'css/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
  {%# TIPS：在低代码平台开发时，请打开下一行代码注释 %}
  {% if true %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}
  {{ site.settings.head_html }}
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, Roboto, "Helvetica Neue", Arial, sans-serif;
    }
  </style>
</head>

<body
  class="antialiased tracking-tight bg-base-100 text-base-content"
  id="js--body"
>
  <!-- Page wrapper -->
  <div class="relative flex flex-col min-h-screen overflow-hidden supports-[overflow:clip]:overflow-clip">
    {% render "header" %}
    <main class="grow">
      {{ content_for_layout }}
    </main>
    {% render "footer" %}
  </div>
  <div id="x-teleport-target" class="relative z-[60] h-0 overflow-hidden"></div>
</body>

</html>
