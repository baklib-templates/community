[
  {
    "name": "theme_info",
    "theme_name": "community",
    "theme_label": "t:theme_label",
    "theme_description": "t:theme_description",
    "theme_version": "1.0.0",
    "theme_scope": "community",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/themes/community/question",
    "theme_support_url": "https://help.baklib.cn/themes/community/question",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/${lang}/index-forum.webp",
      "images/theme/${lang}/index.webp",
      "images/theme/${lang}/comment.webp"
    ],
    "theme_languages": [
      {
        "name": "中文简体",
        "value": "zh-CN"
      },
      {
        "name": "English",
        "value": "en"
      },
      {
        "name": "Deutsch",
        "value": "de"
      },
      {
        "name": "Français",
        "value": "fr"
      },
      {
        "name": "日本語",
        "value": "ja"
      }
    ],
    "recommendations": {
      "color_schemas": {
        "fashion": {
          "name": "Fashion",
          "colors": {
            "--theme-color-primary": "#3D50E0",
            "--theme-color-secondary": "#E91E63",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#2196F3",
            "--theme-color-success": "#4CAF50",
            "--theme-color-warning": "#FFC107"
          }
        },
        "old_school": {
          "name": "Vintage",
          "colors": {
            "--theme-color-primary": "#9C27B0",
            "--theme-color-secondary": "#673AB7",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#418CC8",
            "--theme-color-success": "#29B52F",
            "--theme-color-warning": "#FFC107"
          }
        }
      },
      "initial_pages": {
        "default": {
          "name": "Community",
          "default": false,
          "pages": [
            {
              "name": "Welcome — my first post",
              "slug": "post1",
              "template": "page",
              "settings":
              {
                "content": "This is sample content for the first post."
              }
            },
            {
              "name": "Getting started with discussions",
              "slug": "post2",
              "template": "page",
              "settings":
              {
                "content": "This is sample content for the second post."
              }
            }
          ]
        }
      }
    }
  },
  {
    "name": "t:settings_schema.generic.name",
    "settings": [
      {
        "id": "logo_url",
        "type": "image_picker",
        "ratio": "3:1",
        "width": 150,
        "label": "t:settings_schema.community.logo_url_label",
        "info": "t:settings_schema.community.logo_url_info"
      },
      {
        "id": "default_avatar",
        "type": "image_picker",
        "ratio": "4:4",
        "width": 100,
        "label": "t:settings_schema.community.default_avatar_label",
        "info": "t:settings_schema.community.default_avatar_info"
      },
      {
        "id": "is_allow_published",
        "type": "checkbox",
        "label": "t:settings_schema.community.is_allow_published_label",
        "info": "t:settings_schema.community.is_allow_published_info",
        "default": true
      },
      
      {
        "id": "feedback_useful_type",
        "type": "text",
        "label": "t:settings_schema.community.feedback_useful_type_label",
        "placeholder": "t:settings_schema.community.feedback_useful_type_placeholder",
        "default": "😊"
      },
      {
        "id": "copyright_info",
        "type": "text",
        "label": "t:settings_schema.community.copyright_info_label",
        "placeholder": "t:settings_schema.community.copyright_info_placeholder"
      }
    ]
  },
  {
    "name": "t:settings_schema.community.collections_section_name",
    "settings": [
      {
        "id": "is_show_collection_feature_tags",
        "type": "checkbox",
        "label": "t:settings_schema.community.is_show_collection_feature_tags_label",
        "default": true
      },
      {
        "id": "feature_tags",
        "queryable": true,
        "type": "textarea",
        "label": "t:settings_schema.community.feature_tags_label",
        "rows": 10,
        "info": "t:settings_schema.community.feature_tags_info"
      },
      {
        "id": "collection_tags",
        "queryable": true,
        "type": "textarea",
        "label": "t:settings_schema.community.collection_tags_label",
        "rows": 10,
        "info": "t:settings_schema.community.collection_tags_info"
      }
    ]
  },
  {
    "name": "t:settings_schema.generic.header_name",
    "settings": [
      {
        "id": "header_menu",
        "type": "textarea",
        "label": "t:settings_schema.community.header_menu_label",
        "rows": 10,
        "info": "t:settings_schema.community.header_menu_info",
        "default": "Home[/\nAbout[/s/about\nCollections[/s/tags\nBaklib[https://www.baklib.com"
      },
      {
        "id": "header_menu_html",
        "type": "html",
        "label": "t:settings_schema.generic.settings.header_menu_html.label",
        "info": "t:settings_schema.generic.settings.header_menu_html.info",
        "rows": 10,
        "default": "<a class='underline text-slate-500 hover:no-underline' href='#0'>About</a>",
        "placeholder": "<a class='underline text-slate-500 hover:no-underline' href='#0'>About</a>"
      },
      {
        "id": "footer_menu_html",
        "type": "html",
        "label": "t:settings_schema.generic.settings.footer_menu_html.label",
        "info": "t:settings_schema.generic.settings.footer_menu_html.info",
        "rows": 10,
        "default": "<li><a class='underline text-slate-500 hover:no-underline' href='#0'>About</a></li>",
        "placeholder": "<li><a class='underline text-slate-500 hover:no-underline' href='#0'>About</a></li>"
      }
    ]
  },
  {
    "name": "t:settings_schema.generic.head_title",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "t:settings_schema.generic.settings.head_html.label",
        "info": "t:settings_schema.generic.settings.head_html.info",
        "rows": 10,
        "placeholder": "t:settings_schema.generic.settings.head_html.placeholder"
      }
    ]
  }
]