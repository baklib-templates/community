{% if tag %}
  <a
    class="flex items-center text-sm text-inherit space-x-1 px-1.5 py-0.5 rounded-xl"
    style="
      background-color: hsl({{ tag.color_hls[0] }}, {{ tag.color_hls[1] }}%, 90%);
      color: {{ tag.color }};
    "
    href="{{ tag.path }}" target="_blank"
  >
    {% render 'icon', name: 'tag', class: 'size-3.5 shrink-0' %}
    <span>{{ tag.name }}</span>
  </a>
{% endif %}
