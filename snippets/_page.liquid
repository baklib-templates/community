<!-- Item -->
{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url  %}
    {% assign default_avatar_url = 'images/avatar.svg' |  asset_url %}
{% endunless %}
<article class="bg-white dark:bg-slate-800 rounded-xl shadow-sm p-5 hover:shadow-md transition-shadow border border-slate-100 dark:border-slate-700/50">
        <div class="flex flex-start space-x-4">
            <!-- Avatar -->
            <div class="shrink-0 mt-1.5">
                <img class="w-8 h-8 rounded-full" src="{{ page.author.avatar_url | default: default_avatar_url }}" width="32" height="32" alt="User avatar">
            </div>
            <!-- Content -->
            <div class="grow">
                <!-- Title -->
                <h2 class="font-semibold text-md text-slate-800 dark:text-slate-100 mb-2">
                    <a href="{{ page.path }}" data-turbo="false" class="hover:text-primary">{{ page.link_text }}</a>
                </h2>
                <!-- Tags and Collection -->
                {% if page.settings.tags.size > 0 or page.settings.collection %}
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                        {% if page.settings.collection %}
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-md bg-primary/10 text-primary border border-primary/20">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
                                    <path d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
                                    <path d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
                                </svg>
                                {{ page.settings.collection }}
                            </span>
                        {% endif %}
                        {% if page.settings.tags.size > 0 %}
                            {% for tag in page.settings.tags %}
                                {% render 'tag', tag: tag %}
                            {% endfor %}
                        {% endif %}
                    </div>
                {% endif %}
                <!-- Footer -->
                <footer class="flex flex-wrap text-sm">
                    <div
                        class="flex items-center after:block after:content-['·'] last:after:content-[''] after:text-sm after:text-slate-400 dark:after:text-slate-500 after:px-2">
                        <a class="font-medium text-primary hover:text-primary/80"
                            href="#0">
                            <div class="flex items-center">
                                <svg class="mr-2 fill-current" width="16" height="16"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path
                                        d="M15.686 5.708 10.291.313c-.4-.4-.999-.4-1.399 0s-.4 1 0 1.399l.6.6-6.794 3.696-1-1C1.299 4.61.7 4.61.3 5.009c-.4.4-.4 1 0 1.4l1.498 1.498 2.398 2.398L.6 14.001 2 15.4l3.696-3.697L9.692 15.7c.5.5 1.199.2 1.398 0 .4-.4.4-1 0-1.4l-.999-.998 3.697-6.695.6.6c.599.6 1.199.2 1.398 0 .3-.4.3-1.1-.1-1.499Zm-7.193 6.095L4.196 7.507l6.695-3.697 1.298 1.299-3.696 6.694Z">
                                    </path>
                                </svg>
                                {{ page.author.name }}
                            </div>
                        </a>
                    </div>
                    <div
                        class="flex items-center after:block after:content-['·'] last:after:content-[''] after:text-sm after:text-slate-400 dark:after:text-slate-500 after:px-2">
                        <span class="text-slate-500 dark:text-slate-400">{{ page.created_at | date: "%Y-%m-%d %H:%M" }}</span>
                    </div>
                    <div
                        class="flex items-center after:block after:content-['·'] last:after:content-[''] after:text-sm after:text-slate-400 dark:after:text-slate-500 after:px-2">
                        <span class="text-slate-500 dark:text-slate-400">{{ page.comments | roots | size }} {{ 'generic.comments' | t }}</span>
                    </div>
                </footer>
            </div>
            <!-- Upvote button -->
            <div class="shrink-0">
                <button
                    class="text-xs font-semibold text-center h-12 w-12 border border-primary/60 rounded-lg flex flex-col justify-center items-center hover:border-primary">
                    <svg class="inline-flex fill-primary mt-1.5 mb-1.5" width="12" height="6"
                        xmlns="http://www.w3.org/2000/svg">
                        <path d="m0 6 6-6 6 6z"></path>
                    </svg>
                    <div>{{ page | feedback_type_count: site.settings.feedback_useful_type }}</div>
                </button>
            </div>
        </div>
</article>
