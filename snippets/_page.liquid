<!-- Item -->
{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url  %}
    {% assign default_avatar_url = 'images/avatar.svg' |  asset_url %}
{% endunless %}
<article class="pin-card-soft p-5 hover:border-base-content/20 transition-colors">
        <div class="flex flex-start gap-4">
            {% if site.settings.is_show_lucide_icons %}
            <div class="shrink-0 mt-1 text-base-content/70">
                {% render 'page_icon', page: page, class: 'size-8' %}
            </div>
            {% endif %}
            <!-- Content -->
            <div class="grow min-w-0">
                <!-- Title -->
                <h2 class="font-semibold text-base text-base-content mb-2 flex items-center gap-2 flex-wrap tracking-tight">
                    {% if page.settings.pinned %}
                      <span class="badge badge-sm badge-neutral">{{ 'generic.pinned' | t }}</span>
                    {% endif %}
                    <a href="{{ page.path }}" data-turbo="false" class="hover:underline underline-offset-2">{{ page.link_text }}</a>
                    {% if show_review_badge %}
                      {% if page.published_at == blank %}
                        <span class="badge badge-sm badge-warning">{{ 'generic.reviewing' | t }}</span>
                      {% else %}
                        <span class="badge badge-sm badge-success">{{ 'generic.published' | t }}</span>
                      {% endif %}
                    {% endif %}
                </h2>
                <!-- Tags and Collection -->
                {% if page.settings.tags.size > 0 or page.settings.collection %}
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                        {% if page.settings.collection %}
                            <span class="inline-flex items-center gap-1 px-3 py-1 text-xs font-semibold rounded-full bg-base-100 text-base-content/80 border border-base-300">
                                {{ page.settings.collection }}
                            </span>
                        {% endif %}
                        {% if page.settings.tags.size > 0 %}
                            {% for tag in page.settings.tags %}
                                {% render 'tag', tag: tag %}
                            {% endfor %}
                        {% endif %}
                    </div>
                {% endif %}
                <!-- Footer -->
                <footer class="flex flex-wrap text-sm text-base-content/50">
                    <div
                        class="flex items-center after:block after:content-['·'] last:after:content-[''] after:text-sm after:text-base-content/40 after:px-2">
                        <a class="font-medium text-base-content/70 hover:text-base-content flex items-center gap-1.5"
                            href="#0">
                            <img class="w-4 h-4 rounded-full shrink-0" src="{{ page.author.avatar_url | replace: script_name, '' | default: default_avatar_url }}" width="16" height="16" alt="">
                            {{ page.author.name }}
                        </a>
                    </div>
                    <div
                        class="flex items-center after:block after:content-['·'] last:after:content-[''] after:text-sm after:text-base-content/40 after:px-2">
                        <span>{{ page.created_at | date: "%Y-%m-%d %H:%M" }}</span>
                    </div>
                    <div
                        class="flex items-center after:block after:content-['·'] last:after:content-[''] after:text-sm after:text-base-content/40 after:px-2">
                        <span>{{ page.comments | roots | size }} {{ 'generic.comments' | t }}</span>
                    </div>
                </footer>
            </div>
            <!-- Upvote button -->
            <div class="shrink-0">
                <button
                    class="text-xs font-semibold text-center h-11 w-11 border border-base-300 rounded-2xl flex flex-col justify-center items-center hover:bg-base-100 text-base-content/70">
                    <svg class="inline-flex fill-current mb-0.5" width="12" height="6"
                        xmlns="http://www.w3.org/2000/svg">
                        <path d="m0 6 6-6 6 6z"></path>
                    </svg>
                    <div>{{ page | feedback_type_count: site.settings.feedback_useful_type }}</div>
                </button>
            </div>
        </div>
</article>
