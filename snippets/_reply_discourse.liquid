{% comment %}
  Discourse 风格回复: 头像在内容左侧 + 仅一级折叠 / 更多菜单（dev.to）
  Usage: {% render 'reply_discourse', reply: reply, depth: depth %}
{% endcomment %}
{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url %}
  {% assign default_avatar_url = 'images/avatar.svg' | asset_url %}
{% endunless %}
{% assign reply_depth = depth | default: 0 %}

{% if reply.root %}
  {% assign all_under_root = reply.root.replies | order_by: '-created_at' %}
{% else %}
  {% assign all_under_root = reply.replies | order_by: '-created_at' %}
{% endif %}
{% assign next_depth = reply_depth | plus: 1 %}
{% assign children_count = 0 %}
{% for r in all_under_root %}
  {% if r.parent.id == reply.id %}
    {% assign children_count = children_count | plus: 1 %}
  {% endif %}
{% endfor %}
{% assign is_collapsible = false %}
{% if children_count > 5 %}{% assign is_collapsible = true %}{% endif %}

<li
  class="reply-item {% if reply_depth == 0 %}reply-item--root{% else %}reply-item--nested{% endif %}"
  id="reply_{{ reply.id }}"
  x-data="{ open: false, collapsed: false, menuOpen: false, copied: false }"
  :class="{ 'is-collapsed': collapsed }"
  style="--reply-depth: {{ reply_depth }};"
>
  <div class="reply-row flex gap-2.5">
    <div class="reply-gutter flex flex-col items-center shrink-0 w-9 {% if reply_depth == 0 %}reply-gutter--root{% else %}reply-gutter--nested{% endif %}">
      <img
        class="size-8 rounded-full ring-1 ring-base-300/60"
        src="{{ reply.author.avatar_url | replace: script_name, '' | default: default_avatar_url }}"
        width="32"
        height="32"
        alt=""
      />
      {% if reply_depth == 0 %}
        <button
          type="button"
          class="reply-collapse-btn mt-1"
          @click="collapsed = !collapsed"
          :aria-expanded="(!collapsed).toString()"
          :title="collapsed ? '{{ 'reply_menu.expand' | t | escape }}' : '{{ 'reply_menu.collapse' | t | escape }}'"
          aria-label="{{ 'reply_menu.collapse' | t }}"
        >
          <span class="reply-collapse-icon" :class="collapsed ? 'is-collapsed' : ''" aria-hidden="true"></span>
        </button>
      {% endif %}
    </div>

    <div class="reply-body min-w-0 flex-1">
      <div class="flex items-center gap-1.5 text-sm min-w-0 mb-1">
        <a class="font-semibold text-base-content/85 hover:text-base-content truncate" href="{{ reply.author.profile_url | default: '#' }}">{{ reply.author.name }}</a>
        {% if reply.parent and reply.root.id != reply.parent.id %}
          <span class="text-base-content/45 text-xs shrink-0">→</span>
          <span class="text-base-content/60 text-xs truncate">@{{ reply.reply_to_user.name }}</span>
        {% endif %}
        <span class="text-base-content/35 text-xs shrink-0" aria-hidden="true">·</span>
        <time class="text-xs text-base-content/45 shrink-0 tabular-nums">{{ reply.created_at | date: "%Y-%m-%d %H:%M" }}</time>

        <div class="relative ml-auto shrink-0" @keydown.escape.window="menuOpen = false">
          <button
            type="button"
            class="inline-flex items-center justify-center size-7 rounded-lg text-base-content/45 hover:bg-base-200 hover:text-base-content transition-colors"
            @click.stop="menuOpen = !menuOpen"
            :aria-expanded="menuOpen.toString()"
            aria-haspopup="menu"
            aria-label="{{ 'reply_menu.more' | t }}"
          >
            {% render 'icon', name: 'ellipsis', class: 'size-4' %}
          </button>
          <div
            x-show="menuOpen"
            x-cloak
            @click.outside="menuOpen = false"
            class="reply-more-menu absolute right-0 top-full z-20 mt-1 min-w-[10.5rem] rounded-xl border border-base-300 bg-base-200 py-1 shadow-lg"
            role="menu"
          >
            <button
              type="button"
              role="menuitem"
              class="flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-base-content hover:bg-base-100"
              @click="
                const url = window.location.origin + window.location.pathname + window.location.search + '#reply_{{ reply.id }}';
                window.copyToClipboard(url).then(() => { copied = true; setTimeout(() => copied = false, 2000); }).catch(() => {});
                menuOpen = false;
              "
            >
              {% render 'icon', name: 'link', class: 'size-3.5 shrink-0 text-base-content/55' %}
              <span x-text="copied ? '{{ 'reply_menu.copied' | t | escape }}' : '{{ 'reply_menu.copy_link' | t | escape }}'"></span>
            </button>
            <a
              role="menuitem"
              class="flex w-full items-center gap-2 px-3 py-2 text-sm text-base-content hover:bg-base-100"
              :href="'/s/report-abuse?url=' + encodeURIComponent(window.location.origin + window.location.pathname + window.location.search + '#reply_{{ reply.id }}')"
              @click="menuOpen = false"
            >
              {% render 'icon', name: 'triangle-alert', class: 'size-3.5 shrink-0 text-base-content/55' %}
              <span>{{ 'reply_menu.report_abuse' | t }}</span>
            </a>
          </div>
        </div>
      </div>

      <div class="reply-main" x-show="!collapsed" x-collapse>
        <div class="reply-content ProseMirror prose prose-sm dark:prose-invert max-w-none break-words">
          {{ reply.body }}
        </div>

        {% if current_user %}
          <div class="reply-actions">
            <span
              class="reply-action-btn"
              @click="open = !open"
              role="button"
              tabindex="0"
            >
              {% render 'icon', name: 'message-square', class: 'size-3.5 shrink-0' %}
              {{ 'generic.reply' | t }}
            </span>
            {% if current_user.member_id == reply.author.id %}
              {% form_tag 'reply', reply, method: 'delete' %}
                <input value="destroy_reply_success" autocomplete="off" type="hidden" name="return_template_name">
                <button type="submit" class="reply-action-btn reply-action-btn--danger">
                  {% render 'icon', name: 'x', class: 'size-3.5 shrink-0' %}
                  {{ 'buttons.delete' | t }}
                </button>
              {% endform_tag %}
            {% endif %}
          </div>
          {% if reply.root %}{% assign root = reply.root %}{% else %}{% assign root = reply %}{% endif %}
          {% render 'reply_answer_form', root: root, parent: reply, return_template: 'create_answer_reply_success_discourse', community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}
        {% endif %}

        <div class="reply-children-wrapper" x-data="{ kidsCollapsed: {% if is_collapsible %}true{% else %}false{% endif %} }">
          {% if is_collapsible %}
            <button type="button" class="text-xs text-base-content/55 hover:text-base-content mt-2 mb-1 inline-flex items-center gap-1" @click="kidsCollapsed = !kidsCollapsed" x-show="kidsCollapsed">
              {% render 'icon', name: 'list', class: 'size-3.5 shrink-0' %}
              {{ 'generic.show_replies' | t }} ({{ children_count }})
            </button>
            <button type="button" class="text-xs text-base-content/55 hover:text-base-content mt-2 mb-1 inline-flex items-center gap-1" @click="kidsCollapsed = !kidsCollapsed" x-show="!kidsCollapsed" x-cloak>
              {% render 'icon', name: 'list', class: 'size-3.5 shrink-0' %}
              {{ 'generic.collapse_replies' | t }}
            </button>
          {% endif %}
          <ul class="reply-children" id="answer_{{ reply.id }}_replies_list" {% if is_collapsible %}x-show="!kidsCollapsed"{% endif %}>
            {% for r in all_under_root %}
              {% if r.parent.id == reply.id %}
                {% render 'reply_discourse', reply: r, depth: next_depth, community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</li>
