{% comment %}
  Discourse 风格回复表单：登录用户用 richtext，未登录用户显示 Discourse 风格注册提示
{% endcomment %}
{% if current_user %}
  <div class="flex flex-col sm:flex-row sm:space-x-3 w-full" id="create_reply_{{ target.id }}_form">
    <div class="w-full min-w-0">
      {% render 'community_daily_limit_alert', community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}
      {% unless community_daily_limit_reached %}
      {% form_tag 'reply' %}
        <input value="{{ target.full_slug }}" autocomplete="off" type="hidden" name="target_full_path">
        <input value="create_reply_success_discourse" autocomplete="off" type="hidden" name="return_template_name">
        <input value="true" autocomplete="off" type="hidden" name="reply[published]">
        {% form_field_tag 'richtext', 'reply[body]', content, toolbar: 'simple', under_el_id: '#edit-info-bar-container' %}
        <div id="reply_page_error" class="text-xs text-error mt-1"></div>
        <div class="flex items-center justify-end space-x-3 mt-2">
          <input type="submit" value="{{ 'buttons.submit' | t }}" @click="open = false;name=content.substring(0, 50)" class="btn" />
        </div>
      {% endform_tag %}
      {% endunless %}
    </div>
  </div>
{% else %}
  <div class="rounded-xl border border-primary/20 bg-gradient-to-br from-primary/5 via-base-200/60 to-base-200 p-6">
    <p class="text-base-content mb-2">{{ 'generic.discourse_signup_prompt' | t }}</p>
    <p class="text-sm text-base-content/70 mb-4">{{ 'generic.discourse_signup_benefits' | t }}</p>
    <div class="flex flex-wrap gap-2">
      {% form_tag 'sign_in_with_baklib' %}
        <input value="true" type="hidden" name="sign_up">
        <input type="submit" value="{{ 'buttons.join' | t }}" class="btn btn-sm" data-disable-with="..." />
      {% endform_tag %}
      <button type="button" class="btn btn-sm btn-ghost" onclick="this.closest('.rounded-xl').style.display='none'">
        {{ 'generic.maybe_later' | t }}
      </button>
      <button type="button" class="btn btn-sm btn-ghost text-base-content/60 hover:text-base-content" onclick="this.closest('.rounded-xl').style.display='none'">
        {{ 'generic.no_thanks' | t }}
      </button>
    </div>
  </div>
{% endif %}
