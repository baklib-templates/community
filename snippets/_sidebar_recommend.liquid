{% comment %}
  Usage: {% render 'sidebar_recommend', pages: pages, default_avatar_url: default_avatar_url %}
{% endcomment %}
<div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4">
  <div class="text-md font-semibold uppercase mb-4 text-slate-600 dark:text-slate-400">{{ 'generic.recommend' | t }}</div>
  <ul>
    {% assign index_count = 0 %}
    {% for item in pages %}
      {% if index_count >= 5 %}{% break %}{% endif %}
      {% if item.settings.is_recommend %}
        {% assign index_count = index_count | plus: 1 %}
        <li class="relative pb-4 last-of-type:pb-0">
          <div class="pl-6">
            <div class="text-xs font-medium uppercase text-primary mb-0.5">{{ item.created_at | date: "%Y-%m-%d" }}</div>
            <div class="text-sm mb-2">
              <a class="font-medium text-slate-800 hover:text-slate-900 dark:text-slate-100 dark:hover:text-white" href="{{ item.path }}">{{ item.settings.title | default: item.link_text }}</a>
            </div>
            <div class="flex items-center space-x-2">
              <div class="flex -space-x-3 -ml-0.5">
                {% assign comments = item.comments | roots | order_by: '-created_at' | limit: 3 %}
                {% for comment in comments %}
                  <img class="rounded-full border-2 border-white dark:border-slate-800 box-content" src="{{ comment.author.avatar_url | default: default_avatar_url }}" width="32" height="32" alt="" />
                {% endfor %}
              </div>
              <div class="text-xs font-medium text-slate-500 italic">+{{ item.comments | size }}</div>
            </div>
          </div>
          <div aria-hidden="true" class="absolute top-0.5 -bottom-1 left-0.5 ml-px w-0.5 bg-slate-200 dark:bg-slate-700"></div>
          <div aria-hidden="true" class="absolute top-0.5 left-0 -ml-0.5 w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-500 border-2 border-white dark:border-slate-800"></div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
  <div class="mt-4">
    <a href="/s/feed" class="btn btn-ghost w-full">{{ 'generic.read_more' | t }}</a>
  </div>
</div>
