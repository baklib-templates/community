{% comment %}
  Discourse-style left sidebar: Topics, Tags
  Usage: {% render 'sidebar_discourse_nav' %}
{% endcomment %}
<nav class="pin-card-soft p-4 space-y-4">
  <div>
    <h3 class="text-xs font-bold uppercase tracking-wide text-base-content/40 mb-2 inline-flex items-center gap-1.5">
      {% render 'icon', name: 'navigation', class: 'size-3.5 shrink-0' %}
      <span>{{ 'generic.navigation' | t }}</span>
    </h3>
    <ul class="space-y-1">
      <li>
        <a href="/" class="pin-chip md:w-full md:justify-start">
          {% render 'icon', name: 'home', class: 'size-3.5 shrink-0 opacity-70' %}
          <span>{{ 'generic.home' | t }}</span>
        </a>
      </li>
    </ul>
  </div>

  <div class="mt-4">
    <h3 class="text-xs font-bold uppercase tracking-wide text-base-content/40 mb-3 inline-flex items-center gap-1.5">
      {% render 'icon', name: 'tag', class: 'size-3.5 shrink-0' %}
      <span>{{ 'generic.tags' | t }}</span>
    </h3>
    <div class="flex flex-wrap gap-1.5">
      {% for tag in site.tags %}
        {% render 'tag', tag: tag %}
      {% endfor %}
    </div>
  </div>
</nav>
