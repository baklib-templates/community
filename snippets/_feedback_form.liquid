{% assign default_title = 'snippets.feedback_form.title' | t: '提交反馈' %}
{% assign title = site.plugins.feedback.useful_label | presence | default: default_title %}
{% assign message_enabled = site.plugins.feedback.message_enabled %}
{% assign useful_types = site.plugins.feedback.useful_types %}
{% assign posted_feedback = page.visitor_posted_feedback | default: {} %}

{% form_tag 'feedback', page: page %}
  <section class="space-y-5 p-4">
    {% if title %}
      <h1 class="text-center text-2xl font-bold">{{ title }}</h1>
    {% endif %}

    <div
      class="flex flex-wrap items-center justify-center gap-3"
      x-data="{ selected: '{{ posted_feedback.emoji | default: '' | escape_once }}' }"
    >
      {% if message_enabled %}
        {% for useful_type in useful_types %}
          <label
            class="badge badge-soft inline-flex cursor-pointer py-4"
            :class="{ '!bg-primary/15 !border-primary/40': selected === '{{ useful_type.emoji | escape_once }}' }"
          >
            <input
              type="radio"
              name="{{ form.feedback_emoji_field_name }}"
              value="{{ useful_type.emoji | escape_once }}"
              x-model="selected"
              class="hidden"
            >
            <span class="text-2xl">{{ useful_type.emoji }}</span>
            <span>{{ useful_type.label }}</span>
          </label>
        {% endfor %}
      {% else %}
        {% for useful_type in useful_types %}
          <button
            class="badge badge-soft inline-flex py-4"
            name="{{ form.feedback_emoji_field_name }}"
            value="{{ useful_type.emoji | escape_once }}"
            :class="{ 'bg-base-200': selected === '{{ useful_type.emoji | escape_once }}' }"
          >
            <span class="text-2xl">{{ useful_type.emoji }}</span>
            <span>{{ useful_type.label }}</span>
          </button>
        {% endfor %}
      {% endif %}
    </div>

    {% if message_enabled %}
      <fieldset class="fieldset">
        <legend class="fieldset-legend">{{ 'snippets.feedback_form.message_label' | t: '留言' }}</legend>
        <textarea
          class="textarea h-24 w-full"
          name="{{ form.feedback_message_field_name }}"
          placeholder="{{ 'snippets.feedback_form.message_placeholder' | t: '请输入反馈内容' }}"
        ></textarea>
      </fieldset>
    {% endif %}

    <div class="flex justify-center space-x-4">
      <button type="submit" class="btn btn-primary">{{ 'snippets.feedback_form.submit' | t: '提交' }}</button>
      <button type="button" onclick="this.closest('dialog')?.close()" class="btn">{{ 'snippets.feedback_form.cancel' | t: '取消' }}</button>
    </div>
  </section>
{% endform_tag %}
