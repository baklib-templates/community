<div>
  <div class="mt-5 flex flex-col space-y-5">
    <div>
      <input value="page" autocomplete="off" type="hidden" name="page[template_name]">
      <input value="" autocomplete="off" type="hidden" name="page[template_style]">
      {% capture page_published_flag %}{% render 'page_published_flag' %}{% endcapture %}
      <input value="{{ page_published_flag | strip | default: 'false' }}" autocomplete="off" type="hidden" name="page[published]">
      <label for="title" class="mb-2 inline-flex items-center gap-1.5 font-bold text-base-content">
        {% render 'icon', name: 'pencil', class: 'size-4 shrink-0 text-base-content/55' %}
        <span>{{ 'generic.title' | t }}</span>
      </label>
      <input
      type="text"
      name="page[template_variables][title]"
      value="{% if page.id  %}{{ page.link_text }}{% endif %}"
      class="form-input w-full"
      required />
    </div>

    <div class="pin-card overflow-hidden">
      <label for="content" class="mb-2 inline-flex items-center gap-1.5 px-4 pt-3 font-bold text-base-content">
        {% render 'icon', name: 'file-text', class: 'size-4 shrink-0 text-base-content/55' %}
        <span>{{ 'generic.content' | t }}</span>
      </label>
      {% assign content = page.settings.content %}
      {% form_field_tag 'richtext', 'page[template_variables][content]', content, toolbar: 'full', under_el_id: '#edit-info-bar-container' %}
    </div>

    {% assign collection_options = site.settings.collection_tags | default: '' | newline_to_br | split: '<br />' %}
    {% assign feature_options = site.settings.feature_tags | default: '' | newline_to_br | split: '<br />' %}
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="page_collection" class="mb-2 inline-flex items-center gap-1.5 font-bold text-base-content">
          {% render 'icon', name: 'folder', class: 'size-4 shrink-0 text-base-content/55' %}
          <span>{{ 'generic.collection' | t }}</span>
        </label>
        <select id="page_collection" name="page[template_variables][collection]" class="form-select w-full">
          <option value="">—</option>
          {% for opt in collection_options %}
            {% assign opt_name = opt | strip %}
            {% if opt_name != blank %}
              <option value="{{ opt_name }}" {% if page.settings.collection == opt_name %}selected{% endif %}>{{ opt_name }}</option>
            {% endif %}
          {% endfor %}
        </select>
      </div>
      <div>
        <label for="page_feature" class="mb-2 inline-flex items-center gap-1.5 font-bold text-base-content">
          {% render 'icon', name: 'zap', class: 'size-4 shrink-0 text-base-content/55' %}
          <span>{{ 'generic.feature' | t }}</span>
        </label>
        <select id="page_feature" name="page[template_variables][feature]" class="form-select w-full">
          <option value="">—</option>
          {% for opt in feature_options %}
            {% assign opt_name = opt | strip %}
            {% if opt_name != blank %}
              <option value="{{ opt_name }}" {% if page.settings.feature == opt_name %}selected{% endif %}>{{ opt_name }}</option>
            {% endif %}
          {% endfor %}
        </select>
      </div>
    </div>

    <div>
      <label class="mb-2 inline-flex items-center gap-1.5 font-bold text-base-content">
        {% render 'icon', name: 'tag', class: 'size-4 shrink-0 text-base-content/55' %}
        <span>{{ 'generic.tags' | t }}</span>
      </label>
      {% form_field_tag 'tag', 'page[template_variables][tags]', page %}
    </div>
  </div>
  <div class="my-6 flex flex-wrap gap-3">
    <button type="submit" class="btn2 inline-flex items-center gap-2">
      {% render 'icon', name: 'check', class: 'size-4 shrink-0' %}
      <span>{{ 'buttons.submit' | t }}</span>
    </button>
    <a href="/" class="btn2 btn2-ghost inline-flex items-center gap-2">
      {% render 'icon', name: 'x', class: 'size-4 shrink-0' %}
      <span>{{ 'buttons.cancel' | t }}</span>
    </a>
  </div>
  <ul class="text-sm text-base-content/50 list-disc list-inside space-y-1">
    <li>{{ 'generic.terms1' | t }}</li>
    <li>{{ 'me.post_hint' | t }} <a href="{{ statics['me'] }}" class="font-semibold text-base-content hover:underline">{{ 'generic.my_community' | t }}</a></li>
    <li>{{ 'generic.terms2' | t }}<a href="/s/terms" class="font-semibold text-base-content hover:underline">{{ 'generic.terms_link' | t }}</a>。</li>
  </ul>
</div>
