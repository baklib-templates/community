<header class="sticky top-0 z-50 w-full bg-base-200/95 backdrop-blur-sm border-b border-base-300" id="edit-info-bar-container">
    <div class="px-4 mx-auto max-w-7xl sm:px-6">
        <div class="flex items-center justify-between h-16">
            <!-- Site branding -->
            <div class="mr-4 shrink-0">
                {% if site.settings.logo_url %}
                    <a class="flex items-center gap-2 group" href="/" aria-label="{{ site.name }}">
                        {% assign logo = 'images/demo/logo.svg' | asset_url %}
                        <img src="{{ site.settings.logo_url | default: site.favicon_url | default: logo }}" class="w-auto h-8 rounded-2xl" alt="{{ site.name }}" />
                        <span class="text-lg md:text-xl font-bold tracking-tight text-base-content">{{ site.name }}</span>
                    </a>
                {% else %}
                    <a class="flex items-center gap-2 group" href="/" aria-label="{{ site.name }}">
                        {% assign logo = 'images/demo/logo.svg' | asset_url %}
                        <img src="{{ site.favicon_url | default: logo }}" class="w-auto h-10 rounded-2xl" alt="{{ site.name }}" />
                        <span class="text-lg font-bold tracking-tight text-base-content">{{ site.name }}</span>
                    </a>
                {% endif %}
            </div>

            <nav class="md:hidden">
                <div data-controller="dropdown" class="relative">
                    <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" class="flex items-center p-2 rounded-full hover:bg-base-200">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                            <path fill-rule="evenodd" d="M3 6.75A.75.75 0 0 1 3.75 6h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 6.75ZM3 12a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 12Zm0 5.25a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
                        </svg>
                    </button>
                    <div
                        data-dropdown-target="menu"
                        class="hidden transition transform origin-top-right absolute right-0 rounded-2xl border border-base-300 bg-base-200 py-2 px-2 min-w-[12rem] shadow-lg z-50"
                        data-transition-enter-from="opacity-0 scale-95"
                        data-transition-enter-to="opacity-100 scale-100"
                        data-transition-leave-from="opacity-100 scale-100"
                        data-transition-leave-to="opacity-0 scale-95"
                    >
                        <div class="flex flex-col py-1 space-y-1 text-sm font-semibold">
                            {{ site.settings.header_menu_html }}
                            <hr class="border-base-300 my-1"/>
                            {% if current_user %}
                                <a href="/s/new" class="btn2 btn2-sm">{{ 'buttons.create_post' | t }}</a>
                                {% render 'header_user_identity' %}
                                <a href="{{ statics['me'] }}" class="block w-full px-3 py-2 rounded-xl hover:bg-base-200">{{ 'generic.my_community' | t }}</a>
                                <a href="{{ current_user.profile_url }}" class="block w-full px-3 py-2 rounded-xl hover:bg-base-200" target="_blank" rel="noopener">{{ 'generic.account_profile' | t }}</a>
                                {% form_tag 'sign_out' %}
                                    <button type="submit" class="w-full px-3 py-2 text-left rounded-xl hover:bg-base-200">{{ 'buttons.logout' | t }}</button>
                                {% endform_tag %}
                            {% else %}
                                {% form_tag 'sign_in_with_baklib' %}
                                    <input value="true" type="hidden" name="sign_up">
                                    <input type="submit" value="{{ 'buttons.join' | t }}" class="btn2 btn2-sm w-full" data-disable-with=" ... ">
                                {% endform_tag %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </nav>

            <nav class="hidden md:flex">
                <ul class="flex flex-wrap items-center justify-end gap-2 grow">
                    <li class="hidden md:block">
                        <div class="flex flex-row items-center gap-4 text-sm font-semibold text-base-content">
                            {{ site.settings.header_menu_html }}
                        </div>
                    </li>

                    {% if current_user %}
                        <li><a href="/s/new" class="btn2 btn2-sm">{{ 'buttons.create_post' | t }}</a></li>
                        <li>
                            <div data-controller="dropdown" class="relative">
                                <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" class="btn2 btn2-sm btn2-ghost">
                                    <span>{{ 'generic.my_community' | t }}</span>
                                </button>
                                <div
                                    data-dropdown-target="menu"
                                    class="hidden transition transform origin-top-right absolute right-0 rounded-2xl border border-base-300 bg-base-200 py-2 px-2 min-w-[12rem] shadow-lg z-50"
                                    data-transition-enter-from="opacity-0 scale-95"
                                    data-transition-enter-to="opacity-100 scale-100"
                                    data-transition-leave-from="opacity-100 scale-100"
                                    data-transition-leave-to="opacity-0 scale-95"
                                >
                                    {% render 'header_user_identity' %}
                                    <a href="{{ statics['me'] }}" class="block w-full px-3 py-2 rounded-xl hover:bg-base-200 text-sm font-semibold">{{ 'generic.my_community' | t }}</a>
                                    <a href="{{ current_user.profile_url }}" class="block w-full px-3 py-2 rounded-xl hover:bg-base-200 text-sm font-semibold" target="_blank" rel="noopener">{{ 'generic.account_profile' | t }}</a>
                                    {% form_tag 'sign_out' %}
                                        <button type="submit" class="w-full px-3 py-2 text-left rounded-xl hover:bg-base-200 text-sm font-semibold">{{ 'buttons.logout' | t }}</button>
                                    {% endform_tag %}
                                </div>
                            </div>
                        </li>
                    {% else %}
                        <li>
                            {% form_tag 'sign_in_with_baklib' %}
                                <input value="true" type="hidden" name="sign_up">
                                <input type="submit" value="{{ 'buttons.join' | t }}" class="btn2 btn2-sm" data-disable-with=" ... ">
                            {% endform_tag %}
                        </li>
                    {% endif %}

                    <li>
                        <div class="relative" data-controller="more-menu">
                            <button type="button"
                                    class="p-2 rounded-full hover:bg-base-200 transition-colors text-base-content/60"
                                    data-action="click->more-menu#toggle"
                                    title="{{ 'nav.more_menu_title' | t }}">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
                                        <path d="M11.644 1.59a.75.75 0 0 1 .712 0l9.75 5.25a.75.75 0 0 1 0 1.32l-9.75 5.25a.75.75 0 0 1-.712 0l-9.75-5.25a.75.75 0 0 1 0-1.32l9.75-5.25Z" />
                                        <path d="m3.265 10.602 7.668 4.129a2.25 2.25 0 0 0 2.134 0l7.668-4.13 1.37.739a.75.75 0 0 1 0 1.32l-9.75 5.25a.75.75 0 0 1-.71 0l-9.75-5.25a.75.75 0 0 1 0-1.32l1.37-.738Z" />
                                        <path d="m10.933 19.231-7.668-4.13-1.37.739a.75.75 0 0 0 0 1.32l9.75 5.25c.221.12.489.12.71 0l9.75-5.25a.75.75 0 0 0 0-1.32l-1.37-.738-7.668 4.13a2.25 2.25 0 0 1-2.134-.001Z" />
                                    </svg>
                            </button>
                            <div class="hidden absolute right-0 mt-2 w-64 bg-base-200 border border-base-300 rounded-2xl shadow-lg z-50"
                                    data-more-menu-target="menu">
                                <div class="py-2">
                                <a href="/-/search" class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-base-content hover:bg-base-200 rounded-xl mx-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-base-content/50">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 15.75-2.489-2.489m0 0a3.375 3.375 0 1 0-4.773-4.773 3.375 3.375 0 0 0 4.774 4.774ZM21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                    </svg>
                                    <span>{{ 'nav.site_search' | t }}</span>
                                </a>

                                {% assign header_menus = site.settings.header_menu | newline_to_br | split: '<br />' %}
                                {% for menu_line in header_menus %}
                                    {% assign menu_parts = menu_line | split: '[' %}
                                    {% assign menu_name = menu_parts[0] %}
                                    {% assign menu_url = menu_parts[1] | split: ']' | first %}
                                    <a href="{{ menu_url }}" target="_blank" class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-base-content hover:bg-base-200 rounded-xl mx-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-base-content/50">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m12.75 15 3-3m0 0-3-3m3 3h-7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                        </svg>
                                        <span>{{ menu_name }}</span>
                                    </a>
                                {% endfor %}
                                </div>
                            </div>
                        </div>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</header>
