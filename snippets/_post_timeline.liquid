{% comment %}
  Discourse 风格右侧时间线
  Usage: {% render 'post_timeline', page: page %}
  展示主帖和最新回复的日期
{% endcomment %}
<div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4">
  <h3 class="text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 mb-3">{{ 'generic.timeline' | t }}</h3>
  <div class="relative pl-4 border-l-2 border-slate-200 dark:border-slate-700 space-y-4">
    <div class="relative">
      <div class="absolute -left-[9px] w-3 h-3 rounded-full bg-primary border-2 border-white dark:border-slate-800"></div>
      <div class="text-sm font-medium text-slate-700 dark:text-slate-300">{{ page.created_at | date: "%Y-%m-%d" }}</div>
      <div class="text-xs text-slate-500 dark:text-slate-400">{{ page.created_at | date: "%H:%M" }} · {{ 'generic.original_post' | t }}</div>
    </div>
    {% if page.comments.size > 0 %}
      {% assign last_reply = page.comments | first %}
      {% for c in page.comments %}
        {% assign last_reply = c %}
      {% endfor %}
      <div class="relative">
        <div class="absolute -left-[9px] w-2 h-2 rounded-full bg-slate-400 dark:bg-slate-500 border-2 border-white dark:border-slate-800"></div>
        <div class="text-sm font-medium text-slate-700 dark:text-slate-300">{{ last_reply.created_at | date: "%Y-%m-%d" }}</div>
        <div class="text-xs text-slate-500 dark:text-slate-400">{{ page.comments.size }} {{ 'generic.comments' | t }}</div>
      </div>
    {% endif %}
  </div>
</div>
