{% comment %}
  Discourse 风格右侧时间线
  Usage: {% render 'post_timeline', page: page %}
  展示主帖和最新回复的日期
{% endcomment %}
<div class="bg-base-200 rounded-xl p-4">
  <h3 class="text-xs font-semibold uppercase text-base-content/60 mb-3">{{ 'generic.timeline' | t }}</h3>
  <div class="relative pl-4 border-l-2 border-base-300 space-y-4">
    <div class="relative">
      <div class="absolute -left-[9px] w-3 h-3 rounded-full bg-primary border-2 border-base-100"></div>
      <div class="text-sm font-medium text-base-content">{{ page.created_at | date: "%Y-%m-%d" }}</div>
      <div class="text-xs text-base-content/60">{{ page.created_at | date: "%H:%M" }} · {{ 'generic.original_post' | t }}</div>
    </div>
    {% if page.comments.size > 0 %}
      {% assign last_reply = page.comments | first %}
      {% for c in page.comments %}
        {% assign last_reply = c %}
      {% endfor %}
      <div class="relative">
        <div class="absolute -left-[9px] w-2 h-2 rounded-full bg-base-content/40 border-2 border-base-100"></div>
        <div class="text-sm font-medium text-base-content">{{ last_reply.created_at | date: "%Y-%m-%d" }}</div>
        <div class="text-xs text-base-content/60">{{ page.comments.size }} {{ 'generic.comments' | t }}</div>
      </div>
    {% endif %}
  </div>
</div>
