{% comment %}
  Usage: {% render 'sidebar_stats' %}
{% endcomment %}
{% unless site.settings.is_show_sidebar_stats == false %}
  {% assign articles_count = site.pages['/'].children_in_list | size %}
  {% assign qa_count = site.comments | size %}
  {% assign members_count = site.users | size %}
  {% assign articles_fallback = 'sidebar_stats.articles' | t %}
  {% assign qa_fallback = 'sidebar_stats.qa' | t %}
  {% assign members_fallback = 'sidebar_stats.members' | t %}
  {% assign articles_label = site.settings.sidebar_stats_articles_label | default: articles_fallback %}
  {% assign qa_label = site.settings.sidebar_stats_qa_label | default: qa_fallback %}
  {% assign members_label = site.settings.sidebar_stats_members_label | default: members_fallback %}

  <div class="pin-card-soft p-4">
    <div class="text-sm font-bold uppercase tracking-wide mb-3 text-base-content/50 inline-flex items-center gap-1.5">
      {% render 'icon', name: 'chart-bar', class: 'size-3.5 shrink-0' %}
      <span>{{ 'sidebar_stats.title' | t }}</span>
    </div>
    <ul class="space-y-3">
      <li class="flex items-center gap-2.5">
        {% render 'icon', name: 'file-text', class: 'size-4 shrink-0 text-base-content/55' %}
        <span class="text-sm text-base-content/70">{{ articles_label }}</span>
        <span class="ml-auto text-sm font-semibold tabular-nums text-base-content">{{ articles_count }}</span>
        {% assign articles_unit = 'sidebar_stats.articles_unit' | t %}
        {% if articles_unit != blank %}<span class="text-xs text-base-content/45">{{ articles_unit }}</span>{% endif %}
      </li>
      <li class="flex items-center gap-2.5">
        {% render 'icon', name: 'message-square', class: 'size-4 shrink-0 text-base-content/55' %}
        <span class="text-sm text-base-content/70">{{ qa_label }}</span>
        <span class="ml-auto text-sm font-semibold tabular-nums text-base-content">{{ qa_count }}</span>
        {% assign qa_unit = 'sidebar_stats.qa_unit' | t %}
        {% if qa_unit != blank %}<span class="text-xs text-base-content/45">{{ qa_unit }}</span>{% endif %}
      </li>
      <li class="flex items-center gap-2.5">
        {% render 'icon', name: 'users', class: 'size-4 shrink-0 text-base-content/55' %}
        <span class="text-sm text-base-content/70">{{ members_label }}</span>
        <span class="ml-auto text-sm font-semibold tabular-nums text-base-content">{{ members_count }}</span>
        {% assign members_unit = 'sidebar_stats.members_unit' | t %}
        {% if members_unit != blank %}<span class="text-xs text-base-content/45">{{ members_unit }}</span>{% endif %}
      </li>
    </ul>
  </div>
{% endunless %}
