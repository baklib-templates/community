<div class="flex items-center gap-2 py-2 border-b border-base-300">
  {% if current_user.image %}
    <img src="{{ current_user.image | replace: script_name, '' }}" class="w-6 h-6 rounded-full shrink-0" alt="">
  {% else %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 rounded-full shrink-0">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
    </svg>
  {% endif %}
  <div class="min-w-0 flex flex-col gap-0.5">
    <span class="truncate text-sm font-medium text-base-content">{{ current_user.name }}</span>
    {% if current_user.department_ids != blank %}
      <span class="badge badge-xs badge-primary w-fit">{{ 'generic.organization_user' | t }}</span>
    {% else %}
      <span class="badge badge-xs badge-ghost w-fit">{{ 'generic.regular_user' | t }}</span>
    {% endif %}
  </div>
</div>
