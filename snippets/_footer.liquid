<!-- Site footer -->
<footer class="border-t border-base-300">
    <div class="max-w-7xl px-4 mx-auto sm:px-6">
        <div class="py-8">

            <!-- Top area -->
            <div class="flex flex-col items-center justify-center mb-4 md:flex-row md:justify-between">
                <div class="mr-4 shrink-0">
                    <!-- Logo -->
                    <a class="inline-flex mb-8 group md:mb-0 space-x-2" href="/" aria-label="{{ site.name }}">
                        {% assign logo = 'images/demo/logo.svg' | asset_url %}
                        <img src="{{ site.settings.logo_url | default: logo }}" class="w-auto h-8 rounded-3xl hover:scale-175 hover:rotate-2" alt="{{ site.name }}" />
                    </a>
                    <p>{{ site.settings.slogan }}</p>
                </div>
                <!-- Right links -->
                <div class="mb-2 text-sm font-medium md:order-1 md:mb-0">
                    <div class="inline-flex flex-wrap space-x-6 text-sm">
                        {{ site.settings.footer_menu_html }}
                    </div>
                </div>
            </div>

            <!-- Bottom area -->
            <div class="text-center md:flex md:items-center md:justify-between gap-2 flex-wrap">
                <div class="text-sm text-base-content/70">
                    &copy;{{ site.name }}. All rights reserved.
                    {% if site.settings.copyright_info != blank %}
                      {% if site.settings.copyright_link_url != blank %}
                        <a href="{{ site.settings.copyright_link_url }}" target="_blank" rel="noopener" class="hover:text-primary">{{ site.settings.copyright_info }}</a>
                      {% else %}
                        <span>{{ site.settings.copyright_info }}</span>
                      {% endif %}
                    {% endif %}
                </div>
                {% if site.settings.beian_number != blank %}
                  {% assign beian_href = site.settings.beian_url | default: 'https://beian.miit.gov.cn/' %}
                  <div class="text-sm text-base-content/70">
                    <a href="{{ beian_href }}" target="_blank" rel="noopener" class="hover:text-primary">{{ site.settings.beian_number }}</a>
                  </div>
                {% endif %}
            </div>

        </div>
    </div>
</footer>
