{% if paginate.total_count > 0 %}
  <div class="flex items-center justify-between px-2 py-3 border-t border-base-300">
    {% if paginate.total_pages > 1 %}

      <div class="flex justify-between flex-1 sm:hidden">
        <a data-turbo-action="advance" {% if paginate.prev_page %}href="{{ paginate.url_for[paginate.prev_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-base-content bg-base-200 text-base-content border border-base-300 rounded-md hover:border-base-content/30">{{ "paginate.previous" | t }}</a>
        <a data-turbo-action="advance" {% if paginate.next_page %}href="{{ paginate.url_for[paginate.next_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center px-4 py-2 ml-3 text-sm font-medium text-base-content bg-base-200 text-base-content border border-base-300 rounded-md hover:border-base-content/30">{{ "paginate.next" | t }}</a>
      </div>
      <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
        <div>
          <nav class="inline-flex -space-x-px rounded-md border border-base-300 isolate" aria-label="Pagination">
            <a data-turbo-action="advance" {% if paginate.prev_page %}href="{{ paginate.url_for[paginate.prev_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center px-2 py-2 text-base-content/50 rounded-l-md ring-1 ring-inset ring-base-300 hover:bg-base-200 focus:z-20 focus:outline-offset-0">
              <span class="sr-only">{{ "paginate.previous" | t }}</span>
              <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
              </svg>
            </a>

            {% for i in paginate.series %}
              {% assign type = i | typeof %}
              {% case type %}
                {% when 'string' %}
                  {% if i == 'gap' %}
                    <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-base-content ring-1 ring-inset ring-base-300">...</span>
                  {% else %}
                    <span aria-current="page" class="relative z-10 inline-flex items-center px-4 py-2 text-sm font-semibold text-primary-content bg-primary ring-1 ring-inset ring-primary">{{ i }}</span>
                  {% endif %}
                {% when 'integer' %}
                  <a data-turbo-action="advance" href="{{ paginate.url_for[i] }}" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-base-content ring-1 ring-inset ring-base-300 hover:bg-base-200 focus:z-20 focus:outline-offset-0">{{ i }}</a>
              {% endcase %}
            {% endfor %}

            <a data-turbo-action="advance" {% if paginate.next_page %}href="{{ paginate.url_for[paginate.next_page] }}"{% else %}disabled{% endif %} class="relative inline-flex items-center px-2 py-2 text-base-content/50 rounded-r-md ring-1 ring-inset ring-base-300 hover:bg-base-200 focus:z-20 focus:outline-offset-0">
              <span class="sr-only">{{ "paginate.next" | t }}</span>
              <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
              </svg>
            </a>
          </nav>
        </div>
      </div>

    {% endif %}
  </div>
{% endif %}
