<!-- Search form — Pinterest pill -->
{% form_tag 'search' %}
    <div class="flex flex-wrap">
        <div class="w-full">
            <label class="block text-sm sr-only" for="search">{{ 'generic.search' | t }}</label>
            <div class="relative flex items-center">
                <input type="search" id="search" name="{{ form.keywords_field_name }}" value="{{ search.keywords | escape_once }}" class="form-search-pill" placeholder="{{ 'generic.search_from' | t }}" />
                <div class="absolute inset-0 right-auto flex items-center justify-center pointer-events-none pl-3.5">
                    {% render 'icon', name: 'search', class: 'size-4 shrink-0 text-base-content/50' %}
                </div>
            </div>
        </div>
    </div>
{% endform_tag %}
