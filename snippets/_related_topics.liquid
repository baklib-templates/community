{% comment %}
  相关主题表格 (Discourse 风格)
  Usage: {% render 'related_topics', pages: pages, current_page: page %}
  排除当前页，按 visits_count 或 created_at 排序，取前 5 条
{% endcomment %}
{% assign related = pages | order_by: '-visits_count' | limit: 6 %}
{% assign filtered = "" | split: "," %}
{% assign count = 0 %}
{% for p in related %}
  {% if p.id != current_page.id and count < 5 %}
    {% assign count = count | plus: 1 %}
    {% assign filtered = filtered | push: p %}
  {% endif %}
{% endfor %}

{% assign show_section = false %}
{% for p in pages %}
  {% if p.id != current_page.id %}
    {% assign show_section = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if show_section %}
<div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
  <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary">
      <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
    </svg>
    {{ 'generic.related_topics' | t: '相关主题' }}
  </h2>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 dark:border-slate-700 text-left text-slate-500 dark:text-slate-400">
          <th class="py-3 font-medium">{{ 'generic.title' | t: '话题' }}</th>
          <th class="py-3 font-medium w-20">{{ 'generic.comments' | t }}</th>
          <th class="py-3 font-medium w-24">{{ 'generic.visit' | t }}</th>
          <th class="py-3 font-medium w-28">{{ 'generic.feedback' | t: '活动' }}</th>
        </tr>
      </thead>
      <tbody>
        {% assign shown = 0 %}
        {% for p in pages %}
          {% if p.id != current_page.id and shown < 5 %}
            {% assign shown = shown | plus: 1 %}
            <tr class="border-b border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/30">
              <td class="py-3">
                <a href="{{ p.path }}" class="font-medium text-slate-800 dark:text-slate-200 hover:text-primary">{{ p.link_text }}</a>
                {% if p.settings.tags.size > 0 %}
                  <div class="flex flex-wrap gap-1 mt-1">
                    {% for tag in p.settings.tags %}
                      {% render 'tag', tag: tag %}
                    {% endfor %}
                  </div>
                {% endif %}
              </td>
              <td class="py-3 text-slate-600 dark:text-slate-400">{{ p.comments | size }}</td>
              <td class="py-3 text-slate-600 dark:text-slate-400">{{ p.visits_count | default: 0 }}</td>
              <td class="py-3 text-slate-600 dark:text-slate-400">{{ p.updated_at | date: "%Y-%m-%d" }}</td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
