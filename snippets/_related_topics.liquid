{% comment %}
  相关主题表格 (Discourse 风格)
  Usage: {% render 'related_topics', pages: pages, current_page: page %}
  排除当前页，按 visits_count 或 created_at 排序，取前 5 条
{% endcomment %}
{% assign related = pages | order_by: '-visits_count' | limit: 6 %}
{% assign filtered = "" | split: "," %}
{% assign count = 0 %}
{% for p in related %}
  {% if p.id != current_page.id and count < 5 %}
    {% assign count = count | plus: 1 %}
    {% assign filtered = filtered | push: p %}
  {% endif %}
{% endfor %}

{% assign show_section = false %}
{% for p in pages %}
  {% if p.id != current_page.id %}
    {% assign show_section = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if show_section %}
<div class="mt-12 pt-8 border-t border-base-300">
  <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
    {% render 'icon', name: 'link', class: 'size-5 shrink-0 text-base-content/50' %}
    <span>{{ 'generic.related_topics' | t }}</span>
  </h2>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-base-300 text-left text-base-content/60">
          <th class="py-3 font-medium">{{ 'generic.topic' | t }}</th>
          <th class="py-3 font-medium w-20">{{ 'generic.comments' | t }}</th>
          <th class="py-3 font-medium w-24">{{ 'generic.visit' | t }}</th>
          <th class="py-3 font-medium w-28">{{ 'generic.activity' | t }}</th>
        </tr>
      </thead>
      <tbody>
        {% assign shown = 0 %}
        {% for p in pages %}
          {% if p.id != current_page.id and shown < 5 %}
            {% assign shown = shown | plus: 1 %}
            <tr class="border-b border-base-300 hover:bg-base-200">
              <td class="py-3">
                <a href="{{ p.path }}" class="font-semibold text-base-content hover:underline underline-offset-2 inline-flex items-center gap-2">
                  {% render 'page_icon', page: p, class: 'size-4 shrink-0 text-base-content/60' %}
                  <span>{{ p.link_text }}</span>
                </a>
                {% if p.settings.tags.size > 0 %}
                  <div class="flex flex-wrap gap-1 mt-1">
                    {% for tag in p.settings.tags %}
                      {% render 'tag', tag: tag %}
                    {% endfor %}
                  </div>
                {% endif %}
              </td>
              <td class="py-3 text-base-content/70">{{ p.comments | size }}</td>
              <td class="py-3 text-base-content/70">{{ p.visits_count | default: 0 }}</td>
              <td class="py-3 text-base-content/70">{{ p.updated_at | date: "%Y-%m-%d" }}</td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
