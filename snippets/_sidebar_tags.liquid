{% comment %}
  Usage: {% render 'sidebar_tags' %}
{% endcomment %}
{% assign tag_size = site.tags | size %}
{% if tag_size > 0 %}
  <div class="pin-card-soft p-4">
    <div class="text-sm font-bold uppercase tracking-wide mb-3 text-base-content/50 inline-flex items-center gap-1.5">
      {% render 'icon', name: 'tag', class: 'size-3.5 shrink-0' %}
      <span>{{ 'generic.tags' | t }}</span>
    </div>
    <div class="flex flex-wrap gap-2">
      {% for tag in site.tags %}
        {% render 'tag', tag: tag %}
      {% endfor %}
    </div>
  </div>
{% endif %}
