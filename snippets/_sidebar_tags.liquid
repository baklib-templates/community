{% comment %}
  Usage: {% render 'sidebar_tags' %}
  Uses site.tags
{% endcomment %}
{% assign tag_size = site.tags | size %}
{% if tag_size > 0 %}
  <div class="bg-base-200 rounded-xl p-4">
    <div class="text-md font-semibold uppercase mb-4 text-base-content/70">{{ 'generic.tags' | t }}</div>
    <div class="flex flex-wrap gap-2">
      {% for tag in site.tags %}
        {% render 'tag', tag: tag %}
      {% endfor %}
    </div>
  </div>
{% endif %}