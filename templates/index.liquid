{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url  %}
    {% assign default_avatar_url = 'images/avatar.svg' |  asset_url %}
{% endunless %}
{% assign order_by = params._order_by |  default: '-created_at' %}
{% if order_by == 'related' %}
    {% assign pages = site.pages['/'].children_in_list | where: 'related', current_user.member_id %}
{% else %}
    {% assign pages = site.pages['/'].children_in_list | order_by: order_by %}
    {% query pinned_pages from site.pages['/'].children_in_list %}
      {
        "where": { "settings.pinned_true": true },
        "order_by": ["-created_at"],
        "limit": 50
      }
    {% endquery %}
{% endif %}
{% assign pages_count  =  pages | size %}

<!-- Hero -->
{% render 'hero', page: page %}

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-7xl mx-auto">
    <div class="xl:flex">

        <!-- Left + Middle content -->
        <div class="md:flex flex-1">

            <!-- Left content -->
            <div class="md:w-60 mb-8 md:mb-0 md:pr-2">
                <div class="md:sticky md:top-16 md:h-[calc(100dvh-64px)] md:overflow-x-hidden md:overflow-y-auto no-scrollbar">
                    <div class="md:py-4">

                        <div class="flex justify-between items-center md:block">

                            <!-- Button -->
                            {% if current_user %}
                                <div class="mb-6">
                                    <a href="/s/new" class="btn2 md:w-full inline-flex items-center justify-center gap-2">
                                        {% render 'icon', name: 'plus', class: 'size-4 shrink-0' %}
                                        <span>{{ 'buttons.create_post' | t }}</span>
                                    </a>
                                </div>
                            {% endif %}

                        </div>


                        <!-- Links -->
                        <div
                            class="forum-nav-scroll flex flex-nowrap overflow-x-auto no-scrollbar md:block md:overflow-visible px-4 md:px-0 md:space-y-8 -mx-4 md:mx-0 scroll-pl-4 scroll-pr-4">
                            
                            <!-- Group 1 -->
                            <div class="shrink-0 md:shrink">
                                <div
                                    class="text-xs font-bold text-base-content/40 uppercase tracking-wide mb-2 px-1 md:px-0 inline-flex items-center gap-1.5">
                                    {% render 'icon', name: 'navigation', class: 'size-3.5 shrink-0' %}
                                    <span>{{ 'generic.navigation' | t}}</span>
                                </div>
                                <ul class="flex flex-nowrap md:block gap-1 md:gap-0 mr-3 md:mr-0 pe-4 md:pe-0">
                                    {% assign features = site.settings.feature_tags | newline_to_br | split: '<br />'  %}
                                    {% for feature in features %}
                                        {% assign feature_name = feature | strip %}
                                        {% if feature_name != '' %}
                                        <li class="mr-1 md:mr-0 md:mb-1">
                                            <a class="pin-chip whitespace-nowrap md:w-full md:justify-start"
                                                href="/s/tag?f={{ feature_name | url_encode }}">
                                                {% render 'icon', name: 'zap', class: 'size-3.5 shrink-0 opacity-70' %}
                                                <span>{{ feature_name }}</span>
                                            </a>
                                        </li>
                                        {% endif %}
                                    {% endfor %}

                                </ul>
                            </div>

                            <!-- 自定义集合 -->
                            <div class="shrink-0 md:shrink">
                                <div
                                    class="text-xs font-bold text-base-content/40 uppercase tracking-wide mb-2 px-1 md:px-0 inline-flex items-center gap-1.5">
                                    {% render 'icon', name: 'layers', class: 'size-3.5 shrink-0' %}
                                    <span>{{ 'forum.resource_types' | t }}</span>
                                </div>
                                <ul class="flex flex-nowrap md:block gap-1 md:gap-0 mr-3 md:mr-0 pe-4 md:pe-0">

                                    {% assign collections = site.settings.collection_tags | newline_to_br | split: '<br />'  %}
                                    {% for collection in collections %}
                                        {% assign collection_name = collection | strip %}
                                        {% if collection_name != '' %}
                                            <li class="mr-1 md:mr-0 md:mb-1">
                                                <a class="pin-chip whitespace-nowrap md:w-full md:justify-start"
                                                    href="/s/tag?c={{ collection_name | url_encode }}">
                                                    {% render 'icon', name: 'folder', class: 'size-3.5 shrink-0 opacity-70' %}
                                                    <span>{{ collection_name }}</span>
                                                </a>
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                            </div>
                
                            <!-- Group 2 -->
                            {% assign tag_size = page.settings.tags | size %}
                            {% if tag_size > 0 %}
                                <div class="shrink-0 md:shrink pe-4 md:pe-0">
                                    <div class="text-xs font-bold text-base-content/40 uppercase tracking-wide mb-2 px-1 md:px-0 inline-flex items-center gap-1.5">
                                        {% render 'icon', name: 'tag', class: 'size-3.5 shrink-0' %}
                                        <span>{{ 'generic.tags' | t}}</span>
                                    </div>
                                    <ul class="flex flex-nowrap md:block gap-1 md:gap-0 mr-3 md:mr-0">
                                        {% for tag in page.settings.tags %}
                                            <li class="mr-1 md:mr-0 md:mb-1">
                                                <a class="pin-chip whitespace-nowrap md:w-full md:justify-start"
                                                    href="{{ tag.path }}">
                                                    {% render 'icon', name: 'tag', class: 'size-3.5 shrink-0 opacity-70' %}
                                                    <span>{{ tag.name }}</span>
                                                </a>
                                            </li>
                                        {% endfor %}

                                    </ul>
                                </div>
                            {% endif %}
                        </div>

                    </div>
                </div>
            </div>

            <!-- Middle content -->
            <div class="flex-1 md:ml-8 xl:mx-4 2xl:mx-8">
                <div class="md:py-8">

                    <!-- Buttons group — chip tabs -->
                    <div class="mb-5 flex flex-wrap gap-2">
                        <a href="?_order_by=-created_at" class="{% if order_by == '-created_at' %}pin-chip pin-chip-active{% else %}pin-chip{% endif %}">
                            {% render 'icon', name: 'clock', class: 'size-3.5 shrink-0' %}
                            <span>{{ 'generic.newest' | t }}</span>
                        </a>
                        <a href="?_order_by=-views_count" class="{% if order_by == '-views_count' %}pin-chip pin-chip-active{% else %}pin-chip{% endif %}">
                            {% render 'icon', name: 'trending-up', class: 'size-3.5 shrink-0' %}
                            <span>{{ 'generic.popular' | t }}</span>
                        </a>
                        <a href="?_order_by=related" class="{% if order_by == 'related' %}pin-chip pin-chip-active{% else %}pin-chip{% endif %}">
                            {% render 'icon', name: 'users', class: 'size-3.5 shrink-0' %}
                            <span>{{ 'generic.related' | t }}</span>
                        </a>
                    </div>

                    <!-- List container -->
                    <turbo-frame id="pages_list" class="space-y-3">
                        {% render 'pages_list', pages: pages, pinned_pages: pinned_pages %}
                    </turbo-frame>

                </div>
            </div>

        </div>

        <!-- Right content -->
        <div class="w-full hidden xl:block xl:w-72">
            <div
                class="lg:sticky lg:top-16 lg:h-[calc(100dvh-64px)] lg:overflow-x-hidden lg:overflow-y-auto no-scrollbar">
                <div class="md:py-8">
                    <div class="mb-4">
                        {% render 'search_form' %}
                    </div>

                    <!-- Blocks -->
                    <div class="space-y-4">
                        {% render 'sidebar_stats' %}
                        {% render 'sidebar_recommend', pages: pages, default_avatar_url: default_avatar_url %}
                        {% assign newest_replies = site.comments | order_by: '-created_at' | limit: 5 %}
                        {% render 'sidebar_newest', items: newest_replies, default_avatar_url: default_avatar_url, type: 'replies' %}
                        {% assign popular_replies = site.comments | order_by: '-feedbacks_count' | limit: 3 %}
                        {% render 'sidebar_popular', items: popular_replies, default_avatar_url: default_avatar_url, type: 'replies' %}
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>


{% schema %}
    {
        "name": "t:settings_schema.community_templates.index_home_name",
        "description": "t:settings_schema.community_templates.index_home_description",
        "thumb_url": "images/theme/${lang}/index.png",
        "sub_page_templates": ["page"],
        "settings": [
            {
                "id": "slogan",
                "type": "text",
                "label": "t:settings_schema.community_templates.shared_slogan_label",
                "default": "👋 A maker community to learn and grow together"
            },
            {
                "id": "description",
                "type": "text",
                "label": "t:settings_schema.generic.settings.description.label",
                "default": "👋 Our landing page template works on all devices, so you only have to set it up once, and get beautiful results forever."
            },
            {
                "id": "tags",
                "type": "tag_picker",
                "multiple": true,
                "label": "t:settings_schema.community_templates.shared_tags_label"
            },
            {
                "id": "hero_image_url",
                "type": "image_picker",
                "ratio": "16:6",
                "width": 360,
                "label": "t:settings_schema.community_templates.hero_image_url_label",
                "info": "t:settings_schema.community_templates.hero_image_url_info",
                "default": "images/hero.png"
            },
            {
                "id": "hero_cta_image_url",
                "type": "image_picker",
                "ratio": "4:3",
                "width": 320,
                "label": "t:settings_schema.community_templates.hero_cta_image_url_label",
                "info": "t:settings_schema.community_templates.hero_cta_image_url_info",
                "default": "images/hero-actor.png"
            },
            {
                "id": "text_color",
                "type": "color",
                "default": "#4E3636",
                "label": "t:settings_schema.community_templates.hero_text_color_label",
                "info": "t:settings_schema.community_templates.hero_text_color_info"
            },
            {
                "id": "bg_color",
                "label": "t:settings_schema.community_templates.hero_bg_color_label",
                "type": "color_background",
                "info": "t:settings_schema.community_templates.hero_bg_color_info"
            }
        ]
    }
{% endschema %}
