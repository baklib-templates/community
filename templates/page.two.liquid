{% assign pages = site.pages['/'].children_in_list %}
{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url %}
  {% assign default_avatar_url = 'images/avatar.svg' | asset_url %}
{% endunless %}

<main class="grow">
  <section class="py-6 md:py-10">
    <div class="max-w-7xl px-4 mx-auto sm:px-6">
      {% comment %} Discourse 三栏布局: 左导航 | 主内容 | 右时间线 {% endcomment %}
      <div class="xl:grid xl:grid-cols-[220px_1fr_180px] xl:gap-8">
        <!-- 左侧导航栏 -->
        <aside class="hidden xl:block shrink-0">
          <div class="sticky top-20">
            {% render 'sidebar_discourse_nav' %}
          </div>
        </aside>

        <!-- 主内容区 -->
        <div class="min-w-0">
          <div class="flex flex-col gap-6 lg:flex-row lg:gap-6">
            <!-- Upvotes 按钮 -->
            <div class="flex flex-row lg:flex-col gap-2 shrink-0">
              <div x-data="{ posted_feedback: {% if page.visitor_posted_feedback %}true{% else %}false{% endif %}, feedback_count: {{ page | feedback_type_count: site.settings.feedback_useful_type }} }">
                <div x-show="posted_feedback == true" @click="posted_feedback=false;feedback_count--" x-cloak>
                  {% form_tag 'delete_feedback', page: page, useful_type: site.settings.feedback_useful_type %}
                    <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type }}"
                      :class="{ '!bg-primary': '{{ site.settings.feedback_useful_type }}' === '{{ page.last_feedback_emoji }}' }"
                      class="h-12 w-12 pt-2 items-center text-center flex flex-col rounded border border-primary bg-primary hover:bg-base-300">
                      <svg class="fill-primary-content" width="12" height="6" xmlns="http://www.w3.org/2000/svg"><path d="m0 6 6-6 6 6z"></path></svg>
                      <span class="text-primary-content" x-text="feedback_count"></span>
                    </button>
                  {% endform_tag %}
                </div>
                <div x-show="posted_feedback == false" @click="posted_feedback=true;feedback_count++" x-cloak>
                  {% form_tag 'feedback', page: page %}
                    <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type }}"
                      class="h-12 w-12 pt-2 items-center text-center flex flex-col rounded border border-primary/30 bg-gradient-to-tr from-base-200/20 via-base-200/50 to-base-200/20 hover:bg-base-300">
                      <svg class="fill-primary" width="12" height="6" xmlns="http://www.w3.org/2000/svg"><path d="m0 6 6-6 6 6z"></path></svg>
                      <span x-text="feedback_count"></span>
                    </button>
                  {% endform_tag %}
                </div>
              </div>
            </div>

            <!-- 帖子内容 -->
            <div class="flex-1 min-w-0">
              <article class="mb-10">
                {% comment %} Discourse: 标题 + 标签置顶 {% endcomment %}
                <header class="mb-4">
                  <h1 class="mb-3 text-2xl md:text-3xl font-bold font-aspekta text-base-content flex items-center gap-2">
                    {% render 'page_icon', page: page, class: 'size-8 shrink-0 text-primary' %}
                    <span>{{ page.link_text }}</span>
                  </h1>
                  {% if page.settings.tags.size > 0 %}
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {% for tag in page.settings.tags %}
                        {% render 'tag', tag: tag %}
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% comment %} Discourse: 作者左，时间右 {% endcomment %}
                  <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-2">
                      <img class="w-8 h-8 rounded-full shrink-0" src="{{ page.author.avatar_url | default: default_avatar_url }}" width="32" height="32" alt="" />
                      <a class="font-medium text-primary hover:text-primary/80" href="{{ page.author.profile_url | default: '#' }}">{{ page.author.name }}</a>
                    </div>
                    <div class="text-sm text-base-content/60">
                      {{ page.created_at | date: "%Y-%m-%d %H:%M" }} · {{ page.comments | size }} {{ 'generic.comments' | t }}
                    </div>
                  </div>
                </header>

                <div class="ProseMirror prose dark:prose-invert max-w-none break-words">
                  {{ page.settings.content }}
                </div>

              </article>

              {% if page.author.id == current_user.member_id %}
                <div class="my-4 p-4 rounded-lg border border-base-300 bg-base-200">
                  <div class="flex gap-3">
                    <a href="/s/edit?page_path={{ page.full_slug }}" class="btn2">{{ 'buttons.edit' | t }}</a>
                    {% form_tag 'delete_page', page %}
                      <button type="submit" class="btn2 btn2-ghost">{{ 'buttons.delete' | t }}</button>
                    {% endform_tag %}
                  </div>
                </div>
              {% endif %}

              <!-- 回复列表 -->
              <div data-controller="load_more">
                {% include 'community_daily_limit' %}
                <div class="pb-4 mb-4 border-b border-base-300">
                  <h2 class="text-xl font-semibold">{{ page.comments | size }} {{ 'generic.comments' | t }}</h2>
                </div>

                {% render 'reply_page_form_discourse', target: page, community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}

                {% assign answers = page.comments | roots %}
                <ul id="page_{{ page.id }}_replies_list" data-load_more-target="container">
                  {% paginate_tag answers, per: 4 %}
                    {% for reply in answers %}
                      {% render 'reply_discourse', reply: reply, community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}
                    {% endfor %}
                  {% endpaginate_tag %}
                </ul>
                {{ paginate.next.page }}
                {% if paginate.next_page %}
                  <button id="load_more" data-action="click->load_more#loadMore" data-load_more-url-value="/s/replies?page_path={{ page.full_slug }}&_page={{ paginate.next_page }}"
                    data-load_more-target="button" class="btn2 btn2-ghost mt-4">
                    {{ 'generic.read_more' | t }}
                  </button>
                {% endif %}
              </div>

              {% render 'related_topics', pages: pages, current_page: page %}
            </div>
          </div>
        </div>

        <!-- 右侧时间线 -->
        <aside class="hidden xl:block shrink-0">
          <div class="sticky top-20">
            {% render 'post_timeline', page: page %}
          </div>
        </aside>
      </div>
    </div>
  </section>
</main>

{% schema %}
{
  "name": "t:settings_schema.community_templates.page_two_name",
  "description": "t:settings_schema.community_templates.page_two_description",
  "thumb_url": "images/theme/${lang}/page2.png",
  "sub_page_templates": ["page"],
  "settings": [
    { "id": "title", "type": "text", "placeholder": "", "label": "t:settings_schema.community_templates.post_title_label", "info": "t:settings_schema.community_templates.post_title_info" },
    {
      "id": "icon",
      "type": "select",
      "choices_from": "$site.lucide_icons",
      "queryable": true,
      "label": "t:settings_schema.community_templates.post_icon_label",
      "info": "t:settings_schema.community_templates.post_icon_info"
    },
    { "id": "content", "type": "richtext", "label": "t:settings_schema.community_templates.post_content_label" },
    {
      "id": "collection",
      "type": "select",
      "choices_from": "$site.collection_tags",
      "queryable": true,
      "label": "t:settings_schema.community_templates.post_collection_label",
      "info": "t:settings_schema.community_templates.post_collection_info"
    },
    {
      "id": "feature",
      "type": "select",
      "choices_from": "$site.feature_tags",
      "queryable": true,
      "label": "t:settings_schema.community_templates.post_feature_label",
      "info": "t:settings_schema.community_templates.post_feature_info"
    },
    { "id": "tags", "type": "tag_picker", "multiple": true, "queryable": true, "label": "t:settings_schema.community_templates.post_tags_label" },
    { "id": "is_recommend", "type": "checkbox", "queryable": true, "label": "t:settings_schema.community_templates.post_recommend_label", "info": "t:settings_schema.community_templates.post_recommend_info", "default": false }
  ],
  "user_creatable": true,
  "user_editable": true,
  "user_deletable": true,
  "user_permitted_attributes": ["title", "content"]
}
{% endschema %}
