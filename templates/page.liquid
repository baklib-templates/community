{% assign pages = site.pages['/'].children_in_list %}
{% assign default_avatar_url = site.settings.default_avatar %}
{% unless default_avatar_url  %}
    {% assign default_avatar_url = 'images/avatar.svg' |  asset_url %}
{% endunless %}

<main class="grow bg-base-100">
  <section class="relative">
    <div class="max-w-7xl px-4 mx-auto sm:px-6">
      <div class="pt-6 md:pt-10 pb-12 md:pb-16">
        <div class="md:flex md:justify-between md:gap-8">

          <!-- Page content -->
          <div class="md:grow max-w-5xl">
            <div class="md:pr-6 lg:pr-12">

              <div class="flex flex-col gap-6 lg:flex-row lg:gap-6">

                <div class="flex flex-row lg:flex-col gap-2 shrink-0">
                  <div x-data="{ posted_feedback: {% if page.visitor_posted_feedback %}true{% else %}false{% endif %}, feedback_count: {{ page | feedback_type_count: site.settings.feedback_useful_type }} }">
                    <div x-show="posted_feedback == true" @click="posted_feedback=false;feedback_count--" x-cloak>
                      {% form_tag 'delete_feedback', page: page, useful_type: site.settings.feedback_useful_type %}
                        <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type }}"
                          class="h-11 w-11 items-center text-center flex flex-col justify-center rounded-2xl border border-neutral bg-neutral text-neutral-content hover:brightness-110 shadow-sm">
                          <svg class="fill-current mb-0.5" width="12" height="6" xmlns="http://www.w3.org/2000/svg"><path d="m0 6 6-6 6 6z"></path></svg>
                          <span class="text-xs font-semibold" x-text="feedback_count"></span>
                        </button>
                      {% endform_tag %}
                    </div>
                    <div x-show="posted_feedback == false" @click="posted_feedback=true;feedback_count++" x-cloak>
                      {% form_tag 'feedback', page: page %}
                        <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type }}"
                          class="h-11 w-11 items-center text-center flex flex-col justify-center rounded-2xl border border-base-300 bg-base-200 hover:border-base-content/30 text-base-content/70 shadow-sm">
                          <svg class="fill-current mb-0.5" width="12" height="6" xmlns="http://www.w3.org/2000/svg"><path d="m0 6 6-6 6 6z"></path></svg>
                          <span class="text-xs font-semibold" x-text="feedback_count"></span>
                        </button>
                      {% endform_tag %}
                    </div>
                  </div>
                </div>

                <!-- Content panel elevated above canvas -->
                <div class="min-w-0 grow">
                  <article class="mb-8 pin-card p-6 md:p-8">
                    {% if current_user and page.author.id == current_user.member_id and page.published_at == blank %}
                      <div class="mb-4 rounded-2xl border border-base-300 bg-base-100 px-4 py-3 text-sm">
                        <p class="mb-1 text-base-content/80">{{ 'generic.under_review' | t }}</p>
                        <a href="{{ statics['me'] }}" class="font-semibold text-base-content hover:underline">{{ 'me.view_status' | t }}</a>
                      </div>
                    {% endif %}
                    <!-- Page header -->
                    <header class="mb-6">
                      <h1 class="mb-4 h3 md:h2 flex items-center gap-2 flex-wrap tracking-tight">
                        {% if page.settings.pinned %}
                          <span class="badge badge-sm badge-neutral">{{ 'generic.pinned' | t }}</span>
                        {% endif %}
                        {% render 'page_icon', page: page, class: 'size-8 shrink-0 text-base-content/70' %}
                        <span>{{ page.link_text }}</span>
                      </h1>
                      <div class="flex items-center">
                        <img class="mr-2 rounded-full" src="{{ page.author.avatar_url | replace: script_name, '' | default: default_avatar_url }}" width="20" height="20"
                          alt="" />
                        <div class="text-sm text-base-content/50">
                          <a class="font-semibold text-base-content/80 hover:text-base-content"
                            href="#0">{{ page.author.name }}</a> · <span>{{ page.created_at | date: "%Y-%m-%d %H:%M" }}</span> · <span>{{ page.comments | size }} {{ 'generic.comments' | t}}</span>
                        </div>
                      </div>
                    </header>

                    <!-- Page content -->
                    <div class="ProseMirror dark:prose-invert max-w-none break-words">
                      {{ page.settings.content }}
                    </div>
                    <!--Tags-->
                    {% if page.settings.tags.size > 0 or page.settings.collection or page.settings.feature %}
                      <div class="flex flex-wrap items-center gap-2 py-4 mt-4 text-xs shrink-0">
                          {% for tag in page.settings.tags %}
                            {% render 'tag', tag: tag %}
                          {% endfor %}
                          {% if page.settings.collection %}
                                <a href="/s/tag?c={{ page.settings.collection }}" class="pin-chip text-xs">#{{ page.settings.collection }}</a>
                          {% endif %}
                          {% if page.settings.feature %}
                                <a href="/s/tag?f={{ page.settings.feature }}" class="pin-chip text-xs">#{{ page.settings.feature }}</a>
                          {% endif %}
                      </div>
                    {% endif %}

                  </article>

                  {% if page.author.id == current_user.member_id %}
                    <div class="my-4">
                      <div class="relative p-5 rounded-2xl border border-base-300 bg-base-200">
                        <div class="items-center space-y-3 sm:flex sm:space-y-0 sm:space-x-5">
                            <a href="/s/edit?page_path={{ page.full_slug }}" class="btn2">
                              <span>{{ 'buttons.edit' | t}}</span>
                            </a>
                            {% form_tag 'delete_page', page %}
                              <button class="btn2 btn2-ghost"> {{ 'buttons.delete' | t}} </button>
                            {% endform_tag %}
                        </div>
                      </div>
                    </div>
                  {% endif %}

                  <!-- Comments list -->
                  <div class="pin-card p-6 md:p-8" data-controller="load_more">
                    {% include 'community_daily_limit' %}
                    <!-- Content header -->
                    <div class="pb-4 mb-4 border-b border-base-300">
                      <div class="items-center justify-between text-center md:text-left md:flex">
                          <h2 class="text-xl font-semibold">{{ page.comments | size }} {{ 'generic.comments' | t }}</h2>
                      </div>
                    </div>

                    {% render 'reply_page_form', target: page, community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}

                    <!-- Comments (1st level) -->
                    {% assign answers = page.comments | roots | order_by: '-created_at' %}
                    <ul id="page_{{ page.id }}_replies_list" class="reply-list" data-load_more-target="container">
                      {% paginate_tag answers, per: 4 %}
                        {% for reply in answers %}
                          {% render 'reply', reply: reply, community_daily_limit_reached: community_daily_limit_reached, daily_limit: daily_limit %}
                        {% endfor %}
                      {% endpaginate_tag %}
                    </ul>
                    {{ paginate.next.page  }}
                    {% if paginate.next_page %}
                      <button id="load_more" data-action="click->load_more#loadMore" data-load_more-url-value="/s/replies?page_path={{ page.full_slug }}&_page={{ paginate.next_page }}"
                        data-load_more-target="button" class="btn2 btn2-ghost"
                      >
                        {{ 'generic.read_more' | t}}
                      </button>
                    {% endif %}
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- Sidebar -->
          {% if true %}
          <aside class="hidden md:flex pt-0 pb-12 md:w-64 lg:w-80 md:shrink-0 md:pb-20">
            <div class="md:pl-6 lg:pl-10">
              <!-- Sidebar content -->
              <div class="space-y-6">
                {% render 'search_form' %}
                {% render 'sidebar_tags' %}
                {% render 'sidebar_recommend', pages: pages, default_avatar_url: default_avatar_url %}
                {% assign newest_pages = pages | order_by: '-created_at' | limit: 5 %}
                {% render 'sidebar_newest', items: newest_pages, default_avatar_url: default_avatar_url, type: 'pages' %}
                {% assign popular_pages = pages | order_by: '-visits_count' | limit: 3 %}
                {% render 'sidebar_popular', items: popular_pages, default_avatar_url: default_avatar_url, type: 'pages' %}

              </div>

            </div>
          </aside>
          {% endif %}

        </div>
      </div>
    </div>
  </section>
</main>

{% schema %}
  {
    "name": "t:settings_schema.community_templates.page_detail_name",
    "description": "t:settings_schema.community_templates.page_detail_description",
    "thumb_url": "images/theme/${lang}/page.png",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "placeholder": "",
        "label": "t:settings_schema.community_templates.post_title_label",
        "info": "t:settings_schema.community_templates.post_title_info"
      },
      {
        "id": "icon",
        "type": "select",
        "choices_from": "$site.lucide_icons",
        "queryable": true,
        "label": "t:settings_schema.community_templates.post_icon_label",
        "info": "t:settings_schema.community_templates.post_icon_info"
      },
      {
        "id": "content",
        "type": "richtext",
        "label": "t:settings_schema.community_templates.post_content_label"
      },
      {
        "id": "collection",
        "type": "select",
        "choices_from": "$site.collection_tags",
        "queryable": true,
        "label": "t:settings_schema.community_templates.post_collection_label",
        "info": "t:settings_schema.community_templates.post_collection_info"
      },
      {
        "id": "feature",
        "type": "select",
        "choices_from": "$site.feature_tags",
        "queryable": true,
        "label": "t:settings_schema.community_templates.post_feature_label",
        "info": "t:settings_schema.community_templates.post_feature_info"
      },
      {
        "id": "tags",
        "type": "tag_picker",
        "multiple": true,
        "queryable": true,
        "label": "t:settings_schema.community_templates.post_tags_label"
      },
      {
        "id": "is_recommend",
        "type": "checkbox",
        "queryable": true,
        "label": "t:settings_schema.community_templates.post_recommend_label",
        "info": "t:settings_schema.community_templates.post_recommend_info",
        "default": false
      },
      {
        "id": "pinned",
        "type": "checkbox",
        "queryable": true,
        "label": "t:settings_schema.community_templates.post_pinned_label",
        "info": "t:settings_schema.community_templates.post_pinned_info",
        "default": false
      }
    ],
    "user_creatable": true,
    "user_editable": true,
    "user_deletable": true,
    "user_permitted_attributes": ["title", "content", "collection", "feature", "tags"]
  }
{% endschema %}
